<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="pds_c4" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="61e9ff6a-9bb1-4c7b-b514-cdc8ecc58ba0">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.Long"/>
	<query language="sql"><![CDATA[SELECT
            ISNULL(e.employeeNo, '')  AS employeeNo,
            ISNULL(pd.surname, '')    AS surname,
            ISNULL(pd.firstname, '')  AS firstname,
            ISNULL(pd.middlename, '') AS middlename,
            ISNULL(pd.q34a, '')       AS q34a,
            ISNULL(pd.q34aDetails, '') AS q34aDetails,
            ISNULL(pd.q34b, '')       AS q34b,
            ISNULL(pd.q34bDetails, '') AS q34bDetails,
            ISNULL(pd.q35a, '')       AS q35a,
            ISNULL(pd.q35aDetails, '') AS q35aDetails,
            ISNULL(pd.q35b, '')       AS q35b,
            ISNULL(pd.q35bDetails, '') AS q35bDetails,
            ISNULL(CONVERT(varchar(10), CAST(pd.q35bDateFiled AS date), 101), '') AS q35bDateFiled,
            ISNULL(pd.q35bStatus, '') AS q35bStatus,
            ISNULL(pd.q36, '')        AS q36,
            ISNULL(pd.q36Details, '') AS q36Details,
            ISNULL(pd.q37a, '')       AS q37a,
            ISNULL(pd.q37aDetails, '') AS q37aDetails,
            ISNULL(pd.q37b, '')       AS q37b,
            ISNULL(pd.q37bDetails, '') AS q37bDetails,
            ISNULL(pd.q37c, '')       AS q37c,
            ISNULL(pd.q37cDetails, '') AS q37cDetails,
            ISNULL(pd.q38, '')        AS q38,
            ISNULL(pd.q38Details, '') AS q38Details,
            ISNULL(pd.q39a, '')       AS q39a,
            ISNULL(pd.q39aDetails, '') AS q39aDetails,
            ISNULL(pd.q39b, '')       AS q39b,
            ISNULL(pd.q39bDetails, '') AS q39bDetails,
            ISNULL(pd.q39c, '')       AS q39c,
            ISNULL(pd.q39cDetails, '') AS q39cDetails,
            ISNULL(pd.govIdType, '')   AS govIdType,
            ISNULL(pd.govIdNumber, '') AS govIdNumber,
            ISNULL(CONVERT(varchar(10), CAST(pd.govIdDate AS date), 101), '') AS govIdDate,
            ISNULL(pd.govIdPlace, '')  AS govIdPlace,
            ISNULL(STUFF((
                SELECT CHAR(10) +
                       ISNULL(r.refName, '') +
                       ' | ' + ISNULL(r.address, '') +
                       ' | Tel: ' + ISNULL(r.contactNo, '')
                FROM characterreferences r
                WHERE r.personalDataId = pd.personalDataId
                FOR XML PATH(''), TYPE).value('.', 'NVARCHAR(MAX)'), 1, 1, ''), 'None') AS referencesList
        FROM personaldata pd
        JOIN employee e ON pd.employeeId = e.employeeId
        WHERE e.employeeId = $P{EMPLOYEE_ID}]]></query>
	<field name="employeeNo" class="java.lang.String"/>
	<field name="surname" class="java.lang.String"/>
