<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="pds_c1" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="5066bf5b-5f0d-4129-9022-73ce21684212">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.Long"/>
	<query language="sql"><![CDATA[SELECT
            ISNULL(e.employeeNo, '')                         AS employeeNo,
            ISNULL(pd.surname, '')                           AS surname,
            ISNULL(pd.firstname, '')                         AS firstname,
            ISNULL(pd.middlename, '')                        AS middlename,
            ISNULL(pd.extname, '')                           AS extname,
            ISNULL(CONVERT(varchar(10), CAST(pd.dob AS date), 101), '') AS dob,
            ISNULL(pd.pob, '')                               AS pob,
            CASE pd.sex_id WHEN 1 THEN 'Male' WHEN 2 THEN 'Female' ELSE '' END AS sex,
            CASE pd.civilStatus_id
                WHEN 1 THEN 'Single' WHEN 2 THEN 'Married'
                WHEN 3 THEN 'Widowed' WHEN 4 THEN 'Separated'
                WHEN 5 THEN 'Divorced' ELSE ''
            END AS civilStatus,
            ISNULL(CAST(pd.height AS varchar(10)), '')       AS height,
            ISNULL(CAST(pd.weight AS varchar(10)), '')       AS weight,
            ISNULL(pd.bloodType, '')                         AS bloodType,
            ISNULL(pd.gsisId, '')                            AS gsisId,
            ISNULL(pd.pagibigId, '')                         AS pagibigId,
            ISNULL(pd.philhealthNo, '')                      AS philhealthNo,
            ISNULL(pd.sssNo, '')                             AS sssNo,
            ISNULL(pd.tinNo, '')                             AS tinNo,
            ISNULL(pd.agencyEmpNo, '')                       AS agencyEmpNo,
            ISNULL(pd.citizenship, '')                       AS citizenship,
            ISNULL(pd.resAddress, '') + CASE WHEN pd.resZip IS NOT NULL THEN '  ZIP: ' + pd.resZip ELSE '' END AS resAddress,
            ISNULL(pd.permAddress, '') + CASE WHEN pd.permZip IS NOT NULL THEN '  ZIP: ' + pd.permZip ELSE '' END AS permAddress,
            ISNULL(pd.telNo, '')                             AS telNo,
            ISNULL(pd.mobileNo, '')                          AS mobileNo,
            ISNULL(pd.email, '')                             AS email,
            ISNULL(pd.spouseSurname, '')                     AS spouseSurname,
            ISNULL(pd.spouseFirstname, '')                   AS spouseFirstname,
            ISNULL(pd.spouseMiddlename, '')                  AS spouseMiddlename,
            ISNULL(pd.spouseOccupation, '')                  AS spouseOccupation,
            ISNULL(pd.spouseEmployer, '')                    AS spouseEmployer,
            ISNULL(pd.spouseTelNo, '')                       AS spouseTelNo,
            ISNULL(pd.fatherSurname, '') + ', ' + ISNULL(pd.fatherFirstname, '') + ' ' + ISNULL(pd.fatherMiddlename, '') AS fatherName,
            ISNULL(pd.motherSurname, '') + ', ' + ISNULL(pd.motherFirstname, '') + ' ' + ISNULL(pd.motherMiddlename, '') AS motherName,
            ISNULL(STUFF((
                SELECT CHAR(10) + ISNULL(c.childFullname, '') +
                       CASE WHEN c.dob IS NOT NULL THEN ' (DOB: ' + CONVERT(varchar(10), CAST(c.dob AS date), 101) + ')' ELSE '' END
                FROM children c WHERE c.personalDataId = pd.personalDataId
                FOR XML PATH(''), TYPE).value('.', 'NVARCHAR(MAX)'), 1, 1, ''), 'None') AS childrenList,
            ISNULL(STUFF((
                SELECT CHAR(10) + ISNULL(eb.levelOfEducation, '') + ': ' + ISNULL(eb.nameOfSchool, '') +
                       CASE WHEN eb.degreeCourse IS NOT NULL THEN ' | ' + eb.degreeCourse ELSE '' END +
                       CASE WHEN eb.yearGraduated IS NOT NULL THEN ' (Yr. Grad: ' + CAST(eb.yearGraduated AS varchar) + ')' ELSE '' END +
                       CASE WHEN eb.honorsReceived IS NOT NULL THEN ' | Honors: ' + eb.honorsReceived ELSE '' END
                FROM educationalbackground eb WHERE eb.personalDataId = pd.personalDataId
                FOR XML PATH(''), TYPE).value('.', 'NVARCHAR(MAX)'), 1, 1, ''), 'None') AS educationList
        FROM personaldata pd
        JOIN employee e ON pd.employeeId = e.employeeId
        WHERE e.employeeId = $P{EMPLOYEE_ID}]]></query>
