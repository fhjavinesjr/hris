<jasperReport name="permitSlip" language="java" pageWidth="680" pageHeight="520" columnWidth="640" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="946bd7f7-f3f2-47bc-adc7-39aeb9b69075">
	<property name="ireport.zoom" value="1.4641000000000022"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="webAppPath" class="java.lang.String"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="currentCompanyAddress" class="java.lang.String"/>
	<parameter name="logoleft" class="java.lang.Object"/>
	<parameter name="logoright" class="java.lang.Object"/>
	<parameter name="isDOH" class="java.lang.Boolean"/>
	<parameter name="passSlipId" class="java.lang.Long"/>
	<query language="sql"><![CDATA[SELECT
    CONCAT(
        COALESCE(emp.lastname, ''),
        CASE WHEN COALESCE(emp.lastname, '') <> '' AND COALESCE(emp.firstname, '') <> '' THEN ', ' ELSE '' END,
        COALESCE(emp.firstname, ''),
        CASE WHEN COALESCE(emp.suffix, '') <> '' THEN ' ' + emp.suffix ELSE '' END
    ) AS employee,
    ps.passSlipDate AS permitDate,
    ps.purpose AS purpose,
    COALESCE(ps.details, '') AS reason,
    COALESCE(
        CONCAT(
            COALESCE(appr.lastname, ''),
            CASE WHEN COALESCE(appr.lastname, '') <> '' AND COALESCE(appr.firstname, '') <> '' THEN ', ' ELSE '' END,
            COALESCE(appr.firstname, ''),
            CASE WHEN COALESCE(appr.suffix, '') <> '' THEN ' ' + appr.suffix ELSE '' END
        ),
        ''
    ) AS approvalBy,
    ps.departureTime AS departureOut,
    ps.arrivalTime AS arrivalIn,
    CAST(ISNULL(st.hospitalAgency, 0) AS bit) AS hospitalAgency,
    ISNULL(st.companyName, '') AS currentCompanySetting,
    ISNULL(st.address, '') AS currentCompanyAddressSetting,
    st.leftHeaderLogo AS leftHeaderLogo,
    st.rightHeaderLogo AS rightHeaderLogo
FROM pass_slip ps
LEFT JOIN employee emp ON emp.employeeId = ps.employeeId
LEFT JOIN employee appr ON appr.employeeId = ps.approvedById
OUTER APPLY (
    SELECT TOP 1
        s.companyName,
        s.address,
        s.hospitalAgency,
        s.leftHeaderLogo,
        s.rightHeaderLogo
    FROM settings s
    ORDER BY s.settingsId DESC
) st
WHERE ps.passSlipId = $P{passSlipId}
ORDER BY ps.passSlipDate ASC, ps.departureTime ASC, ps.passSlipId ASC]]></query>
