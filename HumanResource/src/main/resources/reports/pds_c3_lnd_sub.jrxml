<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" name="pds_c3_lnd_sub" pageWidth="612" pageHeight="936" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="57e07fe0-a296-4346-b564-0ec255ea5ba2">
	<property name="ireport.zoom" value="1.9487171000000025"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.Long"></parameter>
	
	<queryString language="SQL"><![CDATA[SELECT
    ISNULL(programName, '') AS name,
    CAST(fromDate AS date) AS dateFrom,
    CAST(toDate AS date) AS dateTo,
    TRY_CONVERT(int, lndHrs) AS noOfHours,
    ISNULL(conductedBy, '') AS sponsoredBy,
    ISNULL(CONVERT(varchar(10), CAST(fromDate AS date), 101), '') + CASE WHEN toDate IS NOT NULL THEN ' - ' + CONVERT(varchar(10), CAST(toDate AS date), 101) ELSE '' END AS dateRange,
    ISNULL(lndType, '') AS typeOfLd,
    CASE WHEN toDate IS NULL THEN '' ELSE CONVERT(varchar(10), CAST(toDate AS date), 101) END AS dateToString
FROM learninganddevelopment
WHERE personalDataId = (SELECT TOP 1 personalDataId FROM personaldata WHERE employeeId = $P{EMPLOYEE_ID})
ORDER BY fromDate DESC]]></queryString>
<field name="name" class="java.lang.String"/>
	<field name="dateFrom" class="java.sql.Date"/>
	<field name="dateTo" class="java.sql.Date"/>
	<field name="noOfHours" class="java.lang.Integer"/>
	<field name="sponsoredBy" class="java.lang.String"/>
	<field name="dateRange" class="java.lang.String"/>
	<field name="typeOfLd" class="java.lang.String"/>
	<field name="dateToString" class="java.lang.String"/>
