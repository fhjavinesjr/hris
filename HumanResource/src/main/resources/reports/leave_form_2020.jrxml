			<element kind="textField" uuid="bd572788-1d2b-4761-9dd6-7362fcd3f687" x="150" y="697" width="108" height="15" fontSize="5.0" pattern="" blankWhenNull="true" hTextAlign="Center" vTextAlign="Middle">
				<printWhenExpression><![CDATA[$F{daysApprovedOther} > 0d]]></printWhenExpression>
				<expression><![CDATA[$F{otherLeaveB}.equals("COVID-19 TREATMENT LEAVE")?"CSC MC No.10, s.2020 dated May 7, 2020":$F{inclusiveDates}]]></expression>
				<box>
					<bottomPen lineWidth="1.0"/>
				</box>
			</element>
			<element kind="textField" uuid="e6261631-3af2-451e-a205-a37fb31b4171" x="18" y="726" width="262" height="15" pdfFontName="Helvetica-Bold" bold="true" vTextAlign="Middle">
				<expression><![CDATA[$F{hospitalAgency} != null && $F{hospitalAgency}?"BY AUTHORITY OF THE SECRETARY OF HEALTH":""]]></expression>
				<box>
					<bottomPen lineWidth="0.0"/>
				</box>
			</element>
			<element kind="textField" uuid="ba21fccf-1730-441e-9082-5b713b29439a" mode="Opaque" x="29" y="547" width="240" height="15" hTextAlign="Center" vTextAlign="Middle">
				<printWhenExpression><![CDATA[$F{otherLeaveB}.equals("COVID-19 TREATMENT LEAVE")]]></printWhenExpression>
				<expression><![CDATA["with FULL PAY"]]></expression>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
			</element>
			<element kind="textField" uuid="65d57078-2dcb-4bdc-8a4a-d35d0a1d925d" x="35" y="97" width="319" height="15" fontSize="7.0" bold="true" hTextAlign="Left" vTextAlign="Middle">
				<expression><![CDATA["Vacation Leave (Sec. 51, Rule XVI, Omnibus Rules Implementing E.O. No. 292)"]]></expression>
				<box leftPadding="0">
					<bottomPen lineWidth="0.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
			</element>
