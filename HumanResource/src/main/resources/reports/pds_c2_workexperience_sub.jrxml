<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" name="pds_c2_workexperience_sub" pageWidth="612" pageHeight="936" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="d07d91b3-fbc4-4bfb-95ea-976c8d8e4d19">
	<property name="ireport.zoom" value="1.6105100000000012"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.Long"></parameter>
	
	<queryString language="SQL"><![CDATA[SELECT
    CAST(fromDate AS date) AS employmentDate,
    CAST(toDate AS date) AS separationDate,
    ISNULL(positionTitle, '') AS position,
    ISNULL(agencyName, '') AS companyAndDepartment,
    TRY_CONVERT(float, monthlySalary) AS salary,
    TRY_CONVERT(float, payGrade) AS salaryIncStep,
    ISNULL(workStatus, '') AS appointmentStatus,
    CASE WHEN LOWER(ISNULL(boolGovernmentService,'')) IN ('yes','y','true','1') THEN CAST(1 AS bit) ELSE CAST(0 AS bit) END AS isGovernmentService,
    CASE WHEN toDate IS NULL THEN 'Present' ELSE CONVERT(varchar(10), CAST(toDate AS date), 101) END AS separationDateTo,
    CASE WHEN payGrade IS NULL THEN '' ELSE CAST(payGrade AS varchar(30)) END AS salaryIncStepString
FROM workexperience
WHERE personalDataId = (SELECT TOP 1 personalDataId FROM personaldata WHERE employeeId = $P{EMPLOYEE_ID})
ORDER BY fromDate DESC]]></queryString>
<field name="employmentDate" class="java.sql.Date"/>
	<field name="separationDate" class="java.sql.Date"/>
	<field name="position" class="java.lang.String"/>
	<field name="companyAndDepartment" class="java.lang.String"/>
	<field name="salary" class="java.lang.Double"/>
	<field name="salaryIncStep" class="java.lang.Double"/>
	<field name="appointmentStatus" class="java.lang.String"/>
	<field name="isGovernmentService" class="java.lang.Boolean"/>
	<field name="separationDateTo" class="java.lang.String"/>
	<field name="salaryIncStepString" class="java.lang.String"/>
	<variable name="governmentService" class="java.lang.String">
		<variableExpression><![CDATA[$F{isGovernmentService}? "Yes": "No"]]></variableExpression>
	</variable>
