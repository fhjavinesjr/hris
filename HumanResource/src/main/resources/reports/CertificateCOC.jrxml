<jasperReport name="CertificateCOC" language="java" pageWidth="680" pageHeight="480" columnWidth="640" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f3d55ae9-1e3c-4bbd-8406-5fc31dda5ac2">
	<property name="ireport.zoom" value="1.9487171000000019"/>
	<property name="ireport.x" value="334"/>
	<property name="ireport.y" value="0"/>
	<parameter name="webAppPath" class="java.lang.String"/>
	<parameter name="logoleft" class="java.lang.Object"/>
	<parameter name="logoright" class="java.lang.Object"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="currentCompanyAddress" class="java.lang.String"/>
	<parameter name="isDOH" class="java.lang.Boolean"/>
	<parameter name="COC_ID" class="java.lang.Long"/>
	<query language="sql"><![CDATA[
SELECT
	CONCAT(
		ISNULL(pd.firstname, ISNULL(e.firstname, '')),
		CASE WHEN ISNULL(pd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', pd.middlename, ' ') END,
		ISNULL(pd.surname, ISNULL(e.lastname, ''))
	) AS employee,
	ISNULL(jp.jobPositionName, ISNULL(e.position, '')) AS position,
	CAST(
		ISNULL(bb.accumulatedHours, 0)
		+ ISNULL(appr.totalApprovedCocHours, 0)
		- ISNULL(used.totalApprovedCtoHours, 0)
	AS float) AS payOffBalance,
	CONCAT(
		ISNULL(headPd.firstname, ISNULL(headEmp.firstname, '')),
		CASE WHEN ISNULL(headPd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', headPd.middlename, ' ') END,
		ISNULL(headPd.surname, ISNULL(headEmp.lastname, ''))
	) AS deptHead,
	CAST(c.dateFiled AS date) AS dateFile,
	CAST(c.dateWorked AS date) AS dateWorked,
	ISNULL(c.workType, '') AS workType,
	ISNULL(c.hoursWorked, 0) AS cocHoursEarned,
	ISNULL(c.actualHoursWorked, 0) AS actualHoursWorked,
	ISNULL(c.cocMultiplier, 1) AS cocMultiplier,
	ISNULL(ot.authorityReference, '') AS authorityReference,
	CONVERT(varchar(10), DATEADD(YEAR, 1, c.dateFiled), 101) AS validUntil,
	CAST(ISNULL(st.hospitalAgency, 0) AS bit) AS hospitalAgency,
	ISNULL(st.companyName, '') AS currentCompanySetting,
	ISNULL(st.address, '') AS currentCompanyAddressSetting,
	st.leftHeaderLogo,
	st.rightHeaderLogo
FROM compensatory_overtime_credit c
LEFT JOIN employee e ON e.employeeId = c.employeeId
LEFT JOIN overtime_request ot ON ot.overtimeRequestId = c.overtimeRequestId
LEFT JOIN personaldata pd ON pd.employeeId = c.employeeId
OUTER APPLY (
	SELECT TOP 1 ea.jobPositionId
	FROM employeeappointment ea
	WHERE ea.employeeId = c.employeeId
	ORDER BY CASE WHEN ea.activeAppointment = 1 THEN 0 ELSE 1 END,
		ea.assumptionToDutyDate DESC,
		ea.employeeAppointmentId DESC
) ap
LEFT JOIN job_position jp ON jp.jobPositionId = ap.jobPositionId
LEFT JOIN employee headEmp ON headEmp.employeeId = c.approvedById
LEFT JOIN personaldata headPd ON headPd.employeeId = headEmp.employeeId
LEFT JOIN coc_beginning_balance bb ON bb.employeeId = c.employeeId
OUTER APPLY (
	SELECT SUM(ISNULL(c2.hoursWorked, 0)) AS totalApprovedCocHours
	FROM compensatory_overtime_credit c2
	WHERE c2.employeeId = c.employeeId
	  AND c2.status = 'Approved'
) appr
OUTER APPLY (
	SELECT SUM(ISNULL(cto.hoursUsed, 0)) AS totalApprovedCtoHours
	FROM compensatory_time_off cto
	WHERE cto.employeeId = c.employeeId
	  AND cto.status = 'Approved'
) used
OUTER APPLY (
	SELECT TOP 1
		s.companyName,
		s.address,
		s.hospitalAgency,
		s.leftHeaderLogo,
		s.rightHeaderLogo
	FROM settings s
	ORDER BY s.settingsId DESC
) st
WHERE c.cocId = $P{COC_ID}
]]></query>
