	<import>net.sf.jasperreports.engine.*</import>
	<parameter name="vlBalance" class="java.lang.Double"/>
	<parameter name="slBalance" class="java.lang.Double"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="currentCompanyAddress" class="java.lang.String"/>
	<parameter name="reportDateAsOf" class="java.util.Date"/>
	<parameter name="lastname" class="java.lang.String"/>
	<parameter name="firstname" class="java.lang.String"/>
	<parameter name="mi" class="java.lang.String"/>
	<parameter name="appOriginalDate" class="java.util.Date"/>
	<parameter name="designation" class="java.lang.String"/>
	<parameter name="status" class="java.lang.String"/>
	<parameter name="service" class="java.lang.String"/>
	<parameter name="civilstat" class="java.lang.String"/>
	<parameter name="position" class="java.lang.String"/>
	<parameter name="datehire" class="java.util.Date"/>
	<parameter name="tinno" class="java.lang.String"/>
	<parameter name="gsisno" class="java.lang.String"/>
	<parameter name="forwardstatus" class="java.lang.String"/>
	<parameter name="webAppPath" class="java.lang.String"/>
	<parameter name="logoleft" class="java.lang.Object"/>
	<parameter name="logoright" class="java.lang.Object"/>
	<parameter name="isDOH" class="java.lang.Boolean"/>
	<parameter name="isSeparated" class="java.lang.String"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.Long"/>
	<parameter name="REPORT_YEAR" class="java.lang.Integer"/>
	<query language="SQL"><![CDATA[SELECT
			CAST(li.cutoffStartDate AS date) AS cutOffStartDate,
			CAST(ISNULL(li.earnedVl, 0) AS float) AS earnedVl,
			CAST(ISNULL(li.earnedSl, 0) AS float) AS earnedSl,
			CAST(ISNULL(li.vacationLeaveUsed, 0) AS float) AS vacationLeaveUsed,
			CAST(ISNULL(li.sickLeaveUsed, 0) AS float) AS sickLeaveUsed,
			CAST(ISNULL(li.lateUndertimeEquivalent, 0) AS float) AS lateUndertimeEquivalent,
			ISNULL(li.lateCount, 0) AS lateCount,
			ISNULL(li.undertimeCount, 0) AS utCount,
			ISNULL(li.leaveParticulars, '') AS leaveParticulars,
			CAST(ISNULL(li.absentCount, 0) AS float) AS absentCount,
			CAST(ISNULL(li.leaveWithoutPaySl, 0) AS float) AS leaveWithoutPaySl,
			CAST(ISNULL(li.leaveWithoutPayVl, 0) AS float) AS leaveWithoutPayVl,
			CAST(li.cutoffEndDate AS date) AS cutOffEndDate,
			CAST(li.processDate AS date) AS processDate,
			CAST(ISNULL(li.sickLeaveBalance, 0) AS float) AS sickLeaveBalance,
			CAST(ISNULL(li.vacationLeaveBalance, 0) AS float) AS vacationLeaveBalance,
			CAST(ISNULL(li.lateUndertimeMinutes, 0) AS float) AS lateUndertimeMin,
			CAST(CASE WHEN ISNULL(li.isBegBalance, 0) = 1 THEN 'true' ELSE 'false' END AS varchar(5)) AS isBegBalance,
			CAST(CASE WHEN YEAR(li.cutoffStartDate) < $P{REPORT_YEAR} THEN 'true' ELSE 'false' END AS varchar(5)) AS isPreviousYear,
			CAST(CASE WHEN ISNULL(li.isLocked, 0) = 1 THEN 'true' ELSE 'false' END AS varchar(5)) AS isLocked,
			ISNULL(pd.surname, ISNULL(e.lastname, '')) AS lastname,
			ISNULL(pd.firstname, ISNULL(e.firstname, '')) AS firstname,
			CASE WHEN ISNULL(pd.middlename, '') = '' THEN '' ELSE LEFT(pd.middlename, 1) + '.' END AS mi,
			ISNULL(jp.jobPositionName, ISNULL(e.position, '')) AS position,
			ISNULL(noa.nature, '') AS status,
			ISNULL(cs.name, '') AS civilstat,
			ISNULL(bu.businessUnitsName, '') AS unitName,
			CAST(ap.assumptionToDutyDate AS date) AS datehire,
			ISNULL(pd.tinNo, '') AS tinno,
			ISNULL(pd.gsisId, '') AS gsisno,
			CAST(ISNULL(st.hospitalAgency, 0) AS bit) AS hospitalAgency,
			ISNULL(st.companyName, '') AS currentCompanySetting,
			ISNULL(st.address, '') AS currentCompanyAddressSetting,
			st.leftHeaderLogo AS leftHeaderLogo,
			st.rightHeaderLogo AS rightHeaderLogo,
			CAST(ISNULL(li.previousVacationLeaveBalance, 0) AS float) AS previousVacationLeaveBalance,
			CAST(ISNULL(li.previousSickLeaveBalance, 0) AS float) AS previousSickLeaveBalance,
			CONCAT('Forwarded balance as of 12/31/', CAST($P{REPORT_YEAR} - 1 AS varchar(4))) AS forwardstatus,
			CASE
				WHEN sep.separationDate IS NOT NULL THEN 'Separated effective ' + CONVERT(varchar(10), sep.separationDate, 101)
				ELSE ''
			END AS isSeparated
		FROM leave_information li
		JOIN employee e ON e.employeeId = li.employeeId
		LEFT JOIN personaldata pd ON pd.employeeId = li.employeeId
		OUTER APPLY (
			SELECT TOP 1
				ea.assumptionToDutyDate,
				ea.jobPositionId,
				ea.natureOfAppointmentId
			FROM employeeappointment ea
			WHERE ea.employeeId = li.employeeId
			ORDER BY CASE WHEN ea.activeAppointment = 1 THEN 0 ELSE 1 END,
				ea.assumptionToDutyDate DESC,
				ea.employeeAppointmentId DESC
		) ap
		LEFT JOIN job_position jp ON jp.jobPositionId = ap.jobPositionId
		LEFT JOIN natureofappointment noa ON noa.natureofappointmentId = ap.natureOfAppointmentId
		LEFT JOIN civilstatus cs ON cs.civilStatusId = pd.civilStatus_id
		OUTER APPLY (
			SELECT TOP 1 mp.businessUnitId
			FROM manage_personnel mp
			WHERE mp.employeeId = li.employeeId
			ORDER BY mp.id DESC
		) mp
		LEFT JOIN businessunits bu ON bu.businessUnitsId = mp.businessUnitId
		OUTER APPLY (
			SELECT TOP 1
				s.companyName,
				s.address,
				s.hospitalAgency,
				s.leftHeaderLogo,
				s.rightHeaderLogo
			FROM settings s
			ORDER BY s.settingsId DESC
		) st
		OUTER APPLY (
			SELECT TOP 1 s2.separationDate
			FROM separation s2
			WHERE s2.employeeId = li.employeeId
			ORDER BY s2.separationDate DESC
		) sep
		WHERE li.employeeId = $P{EMPLOYEE_ID}
		  AND YEAR(li.cutoffStartDate) = $P{REPORT_YEAR}
		ORDER BY li.cutoffStartDate ASC, li.leaveInformationId ASC]]></query>
