	<variable name="openingVlBalance" calculation="First" class="java.lang.Double">
		<expression><![CDATA[$F{previousVacationLeaveBalance}]]></expression>
	</variable>
	<variable name="openingSlBalance" calculation="First" class="java.lang.Double">
		<expression><![CDATA[$F{previousSickLeaveBalance}]]></expression>
	</variable>
	<variable name="forwardStatusValue" calculation="First" class="java.lang.String">
		<expression><![CDATA[$F{forwardstatus}]]></expression>
	</variable>
	<variable name="separatedStatusValue" calculation="First" class="java.lang.String">
		<expression><![CDATA[$F{isSeparated}]]></expression>
	</variable>
