		</element>
		<element kind="textField" uuid="3aa0b1a2-8f5a-4fde-bb92-b9abcca76fc5" mode="Opaque" x="307" y="28" width="206" height="14" fontName="SansSerif" fontSize="10.0" blankWhenNull="true" vTextAlign="Middle">
