				<expression><![CDATA[$F{lndList}]]></expression>
			</element>
		</band>
		<band height="16">
			<element kind="staticText" uuid="4e294b7c-6cb0-4c9c-b0b1-5a4cd567ab7a" x="0" y="0" width="555" height="16" fontName="SansSerif" fontSize="10.0" bold="true">
				<text><![CDATA[VIII.  OTHER INFORMATION]]></text>
			</element>
		</band>
		<band height="20" splitType="Stretch">
			<element kind="textField" uuid="962a46f0-5bd4-4f09-9729-97a7a9639235" x="10" y="0" width="545" height="20" fontName="SansSerif" fontSize="9.0" textAdjust="StretchHeight">
				<expression><![CDATA["Special Skills / Hobbies:\n" + $F{skillOrHobby} + "\n\n" +
"Non-Academic Distinctions / Recognition:\n" + $F{distinction} + "\n\n" +
"Membership in Association/s:\n" + $F{association}]]></expression>
			</element>
		</band>
	</detail>
</jasperReport>
