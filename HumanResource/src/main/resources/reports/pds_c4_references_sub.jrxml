	<parameter name="EMPLOYEE_ID" class="java.lang.Long"></parameter>
	
	<queryString language="SQL"><![CDATA[SELECT
    ISNULL(refName, '') AS name,
    ISNULL(address, '') AS address,
    ISNULL(contactNo, '') AS telNo
FROM characterreferences
WHERE personalDataId = (SELECT TOP 1 personalDataId FROM personaldata WHERE employeeId = $P{EMPLOYEE_ID})
ORDER BY referencesId]]></queryString>
