<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" name="pds_c3_voluntarywork_sub" pageWidth="612" pageHeight="936" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="8938af32-4eb6-42d1-a3c6-2884d4a6fa81">
	<property name="ireport.zoom" value="1.7715610000000013"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.Long"></parameter>
	
	<queryString language="SQL"><![CDATA[SELECT
    ISNULL(organizationName, '') AS nameAndAddress,
    CAST(fromDate AS date) AS dateFrom,
    CAST(toDate AS date) AS dateTo,
    TRY_CONVERT(int, voluntaryHrs) AS noOfHours,
    ISNULL(positionTitle, '') AS positionAndNature,
    CASE WHEN toDate IS NULL THEN '' ELSE CONVERT(varchar(10), CAST(toDate AS date), 101) END AS dateToString
FROM voluntarywork
WHERE personalDataId = (SELECT TOP 1 personalDataId FROM personaldata WHERE employeeId = $P{EMPLOYEE_ID})
ORDER BY fromDate DESC]]></queryString>
<field name="nameAndAddress" class="java.lang.String"/>
	<field name="dateFrom" class="java.sql.Date"/>
	<field name="dateTo" class="java.sql.Date"/>
	<field name="noOfHours" class="java.lang.Integer"/>
	<field name="positionAndNature" class="java.lang.String"/>
	<field name="dateToString" class="java.lang.String"/>
