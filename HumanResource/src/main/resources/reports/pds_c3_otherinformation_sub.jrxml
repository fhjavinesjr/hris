	<parameter name="EMPLOYEE_ID" class="java.lang.Long"></parameter>
	
	<queryString language="SQL"><![CDATA[SELECT
    ISNULL(skillOrHobby, '') AS skill,
    ISNULL(distinction, '') AS recognition,
    ISNULL(association, '') AS organization
FROM personaldata
WHERE employeeId = $P{EMPLOYEE_ID}]]></queryString>
