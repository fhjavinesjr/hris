<jasperReport name="OvertimeAuthorization" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a9324661-f00c-4ff9-8ab7-a0f0dc762247">
	<property name="ireport.zoom" value="1.9487171000000014"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="currentCompanyAddress" class="java.lang.String"/>
	<parameter name="recommendedBy" class="java.lang.String"/>
	<parameter name="recommendedByPos" class="java.lang.String"/>
	<parameter name="approvedBy" class="java.lang.String"/>
	<parameter name="approvedByPos" class="java.lang.String"/>
	<parameter name="isJobOrder" class="java.lang.Boolean"/>
	<parameter name="requestedBy" class="java.lang.String"/>
	<parameter name="requestedByPos" class="java.lang.String"/>
	<parameter name="OVERTIME_REQUEST_ID" class="java.lang.Long"/>
	<query language="sql"><![CDATA[
SELECT
	CONCAT(
		ISNULL(pd.firstname, ISNULL(e.firstname, '')),
		CASE WHEN ISNULL(pd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', pd.middlename, ' ') END,
		ISNULL(pd.surname, ISNULL(e.lastname, ''))
	) AS fullname,
	ISNULL(bu.businessUnitsName, '') AS businessUnit,
	CAST(ot.dateTimeFrom AS DATE) AS dateCovered,
	ISNULL(ot.netAuthorizedHours, ISNULL(ot.totalHours, 0)) AS noOfHours,
	ISNULL(ot.purpose, '') AS purpose,
	CAST(ISNULL(st.hospitalAgency, 0) AS bit) AS hospitalAgency,
	ISNULL(st.companyName, '') AS currentCompanySetting,
	ISNULL(st.address, '') AS currentCompanyAddressSetting,
	st.leftHeaderLogo,
	st.rightHeaderLogo,
	CAST(CASE WHEN LOWER(ISNULL(reqNoa.nature, '')) LIKE '%job order%' THEN 1 ELSE 0 END AS bit) AS isJobOrder,
	CONCAT(
		ISNULL(reqPd.firstname, ISNULL(reqEmp.firstname, '')),
		CASE WHEN ISNULL(reqPd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', reqPd.middlename, ' ') END,
		ISNULL(reqPd.surname, ISNULL(reqEmp.lastname, ''))
	) AS requestedBy,
	ISNULL(reqPos.jobPositionName, '') AS requestedByPos,
	CONCAT(
		ISNULL(recPd.firstname, ISNULL(recEmp.firstname, '')),
		CASE WHEN ISNULL(recPd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', recPd.middlename, ' ') END,
		ISNULL(recPd.surname, ISNULL(recEmp.lastname, ''))
	) AS recommendedBy,
	ISNULL(recPos.jobPositionName, '') AS recommendedByPos,
	CONCAT(
		ISNULL(appPd.firstname, ISNULL(appEmp.firstname, '')),
		CASE WHEN ISNULL(appPd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', appPd.middlename, ' ') END,
		ISNULL(appPd.surname, ISNULL(appEmp.lastname, ''))
	) AS approvedBy,
	ISNULL(appPos.jobPositionName, '') AS approvedByPos
FROM overtime_request ot
LEFT JOIN employee e ON e.employeeId = ot.employeeId
LEFT JOIN personaldata pd ON pd.employeeId = ot.employeeId
LEFT JOIN employee reqEmp ON reqEmp.employeeId = ot.employeeId
LEFT JOIN personaldata reqPd ON reqPd.employeeId = reqEmp.employeeId
LEFT JOIN employee recEmp ON recEmp.employeeId = ot.recommendedById
LEFT JOIN personaldata recPd ON recPd.employeeId = recEmp.employeeId
LEFT JOIN employee appEmp ON appEmp.employeeId = ot.approvedById
LEFT JOIN personaldata appPd ON appPd.employeeId = appEmp.employeeId
OUTER APPLY (
	SELECT TOP 1 mp.businessUnitId
	FROM manage_personnel mp
	WHERE mp.employeeId = ot.employeeId
	ORDER BY mp.id DESC
) mp
LEFT JOIN businessunits bu ON bu.businessUnitsId = mp.businessUnitId
OUTER APPLY (
	SELECT TOP 1
		s.companyName,
		s.address,
		s.hospitalAgency,
		s.leftHeaderLogo,
		s.rightHeaderLogo
	FROM settings s
	ORDER BY s.settingsId DESC
) st
OUTER APPLY (
	SELECT TOP 1 ea.jobPositionId, ea.natureOfAppointmentId
	FROM employeeappointment ea
	WHERE ea.employeeId = reqEmp.employeeId
	ORDER BY CASE WHEN ea.activeAppointment = 1 THEN 0 ELSE 1 END,
		ea.assumptionToDutyDate DESC,
		ea.employeeAppointmentId DESC
) reqAppt
LEFT JOIN job_position reqPos ON reqPos.jobPositionId = reqAppt.jobPositionId
LEFT JOIN natureofappointment reqNoa ON reqNoa.natureofappointmentId = reqAppt.natureOfAppointmentId
OUTER APPLY (
	SELECT TOP 1 ea.jobPositionId
	FROM employeeappointment ea
	WHERE ea.employeeId = recEmp.employeeId
	ORDER BY CASE WHEN ea.activeAppointment = 1 THEN 0 ELSE 1 END,
		ea.assumptionToDutyDate DESC,
		ea.employeeAppointmentId DESC
) recAppt
LEFT JOIN job_position recPos ON recPos.jobPositionId = recAppt.jobPositionId
OUTER APPLY (
	SELECT TOP 1 ea.jobPositionId
	FROM employeeappointment ea
	WHERE ea.employeeId = appEmp.employeeId
	ORDER BY CASE WHEN ea.activeAppointment = 1 THEN 0 ELSE 1 END,
		ea.assumptionToDutyDate DESC,
		ea.employeeAppointmentId DESC
) appAppt
LEFT JOIN job_position appPos ON appPos.jobPositionId = appAppt.jobPositionId
WHERE ot.overtimeRequestId = $P{OVERTIME_REQUEST_ID}
]]></query>
