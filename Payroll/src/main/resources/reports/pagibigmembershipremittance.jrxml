			<element kind="textField" uuid="19eb3a5a-dd0f-43bd-86e2-d4ac2fb57108" x="708" y="0" width="104" height="25" fontSize="10.0" pattern="#,##0.00" blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
