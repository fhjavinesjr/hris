<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="NUMFC_REMITTANCE_LIST_MONTHLY" language="java" pageWidth="1010" pageHeight="668" orientation="Landscape" columnWidth="985" leftMargin="5" rightMargin="20" topMargin="2" bottomMargin="20" uuid="6e52e5de-1320-4314-a334-3e0a16f07970">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="0.9313819845887548"/>
	<property name="ireport.x" value="99"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<import>net.sf.jasperreports.engine.*</import>
	<import>java.util.*</import>
	<import>net.sf.jasperreports.engine.data.*</import>
	<parameter name="salaryPeriodKey" class="java.lang.String"/>
	<parameter name="runDate" forPrompting="false" class="java.util.Date"/>
	<parameter name="currentCompany" forPrompting="false" class="java.lang.String"/>
	<parameter name="employerOfficeId" forPrompting="false" class="java.lang.String"/>
	<parameter name="companyAddress" forPrompting="false" class="java.lang.String"/>
	<parameter name="employerPagIbigNo" forPrompting="false" class="java.lang.String"/>
	<parameter name="periodCovered" forPrompting="false" class="java.lang.String"/>
	<parameter name="certifiedBy" forPrompting="false" class="java.lang.String"/>
	<parameter name="certifiedByEmployeeNo" forPrompting="false" class="java.lang.String"/>
	<parameter name="perCov" class="java.lang.String"/>
	<query language="SQL"><![CDATA[WITH remittance_lines AS (
    SELECT
        pd.employeeNo,
        pd.employeeName,
        SUM(COALESCE(pdd.amount, 0)) AS eeAmount,
        SUM(COALESCE(pdd.employerShare, 0)) AS erAmount
    FROM payroll_detail pd
    INNER JOIN payroll_detail_deduction pdd ON pdd.payroll_detail_id = pd.id
    WHERE pd.salaryPeriodKey = $P{salaryPeriodKey}
      AND (
             UPPER(LTRIM(RTRIM(pdd.deductionCode))) IN ('HDMF','PAGIBIG')
          OR UPPER(REPLACE(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(pdd.deductionName)), ' ', ''), '-', ''), '_', ''), '.', '')) IN ('HDMF','PAGIBIG','PAGIBIGPREMIUM','PAGIBIGCONTRIBUTION')
      )
    GROUP BY pd.employeeNo, pd.employeeName

    UNION ALL

    SELECT
        ah.employeeNo,
        ah.employeeName,
        SUM(COALESCE(al.amount, 0)) AS eeAmount,
        CAST(0 AS FLOAT) AS erAmount
    FROM payroll_adjustment_header ah
    INNER JOIN payroll_adjustment_line al ON al.header_id = ah.id
    WHERE ah.salaryPeriodKey = $P{salaryPeriodKey}
      AND al.type = 'DEDUCTION'
      AND (
             UPPER(LTRIM(RTRIM(al.code))) IN ('HDMF','PAGIBIG')
          OR UPPER(REPLACE(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(al.name)), ' ', ''), '-', ''), '_', ''), '.', '')) IN ('HDMF','PAGIBIG','PAGIBIGPREMIUM','PAGIBIGCONTRIBUTION')
      )
      AND (
              ah.status = 'POSTED'
           OR (ah.status = 'PENDING' AND NOT EXISTS (
                SELECT 1 FROM payroll_period_lock ppl WHERE ppl.salaryPeriodKey = ah.salaryPeriodKey
              ))
        )
    GROUP BY ah.employeeNo, ah.employeeName
), grouped AS (
    SELECT employeeNo, employeeName, SUM(eeAmount) AS eeAmount, SUM(erAmount) AS erAmount
    FROM remittance_lines
    GROUP BY employeeNo, employeeName
)
SELECT
    ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName) AS lastname,
    CAST(COALESCE(eeAmount,0) AS FLOAT) AS eeAmount,
    ISNULL(NULLIF(LTRIM(RTRIM(per.pagibigId)), ''), '') AS pagIbigNo,
    ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '') AS firstname,
    ISNULL(NULLIF(LTRIM(RTRIM(per.middlename)), ''), '') AS middlename,
    CAST(COALESCE(erAmount,0) AS FLOAT) AS erAmount,
    '' AS accountNo,
    '' AS me,
    ISNULL(NULLIF(LTRIM(RTRIM(per.extname)), ''), '') AS extName,
    '' AS remarks,
    CAST(ROW_NUMBER() OVER (ORDER BY ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName), ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '')) AS INT) AS countNum,
    ISNULL(cert.position, '') AS certifiedByPosition
FROM grouped
LEFT JOIN employee emp ON emp.employeeNo = grouped.employeeNo
LEFT JOIN personaldata per ON per.employeeId = emp.employeeId
OUTER APPLY (
    SELECT TOP 1 COALESCE(jp.jobPositionName, certEmp.position, pdCert.department, '') AS position
    FROM employee certEmp
    OUTER APPLY (
        SELECT TOP 1
            ea0.jobPositionId,
            ea0.assumptionToDutyDate,
            ea0.activeAppointment,
            ea0.employeeAppointmentId
        FROM employeeappointment ea0
        WHERE ea0.employeeId = certEmp.employeeId
        ORDER BY
            CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
            ea0.assumptionToDutyDate DESC,
            ea0.employeeAppointmentId DESC
    ) ea
    LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
    LEFT JOIN payroll_detail pdCert ON pdCert.employeeNo = certEmp.employeeNo AND pdCert.salaryPeriodKey = $P{salaryPeriodKey}
    WHERE (
        certEmp.employeeNo = $P{certifiedByEmployeeNo}
        OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(ISNULL(pdCert.employeeName, ''))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
        OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(CONCAT(ISNULL(certEmp.firstname, ''), ' ', ISNULL(certEmp.lastname, '')))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
        OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(CONCAT(ISNULL(certEmp.lastname, ''), ' ', ISNULL(certEmp.firstname, '')))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
    )
) cert
WHERE COALESCE(eeAmount,0) <> 0 OR COALESCE(erAmount,0) <> 0
ORDER BY ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName), ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '')]]></query>
