<jasperReport name="gsisreport" language="java" pageWidth="1400" pageHeight="900" orientation="Landscape" columnWidth="1378" leftMargin="2" rightMargin="20" topMargin="20" bottomMargin="20" uuid="156b81ab-7e35-43ec-b55b-3cf6353fb39f">
	<property name="ireport.zoom" value="1.610510000000029"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="salaryPeriodKey" class="java.lang.String"/>
	<parameter name="salaryDate" class="java.lang.String"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="officeCode" class="java.lang.String"/>
	<parameter name="preparedBy" class="java.lang.String"/>
	<parameter name="certifiedBy" class="java.lang.String"/>
	<parameter name="preparedByEmployeeNo" class="java.lang.String"/>
	<parameter name="certifiedByEmployeeNo" class="java.lang.String"/>
	<parameter name="preparedByPos" class="java.lang.String"/>
	<parameter name="certifiedByPos" class="java.lang.String"/>
	<query language="SQL"><![CDATA[WITH remittance_lines AS (
    SELECT
        pd.employeeNo,
        pd.employeeName,
        SUM(COALESCE(pdd.amount, 0)) AS ps,
        SUM(COALESCE(pdd.employerShare, 0)) AS gs
    FROM payroll_detail pd
    INNER JOIN payroll_detail_deduction pdd ON pdd.payroll_detail_id = pd.id
    WHERE pd.salaryPeriodKey = $P{salaryPeriodKey}
      AND (
             UPPER(LTRIM(RTRIM(pdd.deductionCode))) IN ('GSIS')
          OR UPPER(REPLACE(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(pdd.deductionName)), ' ', ''), '-', ''), '_', ''), '.', '')) IN ('GSIS','GSISPREMIUM','GSISLIFEINSURANCE','GSISCONTRIBUTION')
      )
    GROUP BY pd.employeeNo, pd.employeeName

    UNION ALL

    SELECT
        ah.employeeNo,
        ah.employeeName,
        SUM(COALESCE(al.amount, 0)) AS ps,
        CAST(0 AS FLOAT) AS gs
    FROM payroll_adjustment_header ah
    INNER JOIN payroll_adjustment_line al ON al.header_id = ah.id
    WHERE ah.salaryPeriodKey = $P{salaryPeriodKey}
      AND al.type = 'DEDUCTION'
      AND (
             UPPER(LTRIM(RTRIM(al.code))) IN ('GSIS','GSIS_CASCADE')
          OR UPPER(REPLACE(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(al.name)), ' ', ''), '-', ''), '_', ''), '.', '')) IN ('GSIS','GSISPREMIUM','GSISLIFEINSURANCE','GSISCONTRIBUTION','GSISCASCADE')
      )
      AND (
              ah.status = 'POSTED'
           OR (ah.status = 'PENDING' AND NOT EXISTS (
                SELECT 1 FROM payroll_period_lock ppl WHERE ppl.salaryPeriodKey = ah.salaryPeriodKey
              ))
        )
    GROUP BY ah.employeeNo, ah.employeeName
), grouped AS (
    SELECT employeeNo, employeeName, SUM(ps) AS ps, SUM(gs) AS gs
    FROM remittance_lines
    GROUP BY employeeNo, employeeName
), signatory_positions AS (
    SELECT
        ISNULL(prep.position, '') AS preparedByPositionResolved,
        ISNULL(cert.position, '') AS certifiedByPositionResolved
    FROM (SELECT 1 AS oneRow) oneRow
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1
                ea0.jobPositionId,
                ea0.assumptionToDutyDate,
                ea0.activeAppointment,
                ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY
                CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                ea0.assumptionToDutyDate DESC,
                ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{salaryPeriodKey}
        WHERE (
            e.employeeNo = $P{preparedByEmployeeNo}
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(ISNULL(pd.employeeName, ''))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{preparedBy})), ' ', ''), '.', ''), '-', ''))
        )
    ) prep
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1
                ea0.jobPositionId,
                ea0.assumptionToDutyDate,
                ea0.activeAppointment,
                ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY
                CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                ea0.assumptionToDutyDate DESC,
                ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{salaryPeriodKey}
        WHERE (
            e.employeeNo = $P{certifiedByEmployeeNo}
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(ISNULL(pd.employeeName, ''))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
        )
    ) cert
)
SELECT
    signatory_positions.preparedByPositionResolved,
    signatory_positions.certifiedByPositionResolved,
    '' AS policyNo,
    ISNULL(NULLIF(LTRIM(RTRIM(per.gsisId)), ''), '') AS bpNo,
    ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName) AS lastname,
    ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '') AS firstname,
    ISNULL(NULLIF(LTRIM(RTRIM(per.middlename)), ''), '') AS middlename,
    ISNULL(NULLIF(LTRIM(RTRIM(per.extname)), ''), '') AS pref,
    '' AS app,
    CAST(COALESCE(ps,0) AS FLOAT) AS ps,
    CAST(COALESCE(gs,0) AS FLOAT) AS gs,
    CAST(per.dob AS DATE) AS bdate,
    CAST(0 AS FLOAT) AS conso,
    CAST(0 AS FLOAT) AS edu,
    CAST(0 AS FLOAT) AS ec,
    CAST(0 AS FLOAT) AS gcal,
    CAST(0 AS FLOAT) AS gpol,
    CAST(0 AS FLOAT) AS ceap,
    CAST(0 AS FLOAT) AS gmpl,
    CAST(0 AS FLOAT) AS gcom
FROM grouped
CROSS JOIN signatory_positions
LEFT JOIN employee emp ON emp.employeeNo = grouped.employeeNo
LEFT JOIN personaldata per ON per.employeeId = emp.employeeId
WHERE COALESCE(ps,0) <> 0 OR COALESCE(gs,0) <> 0
ORDER BY ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName), ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '')]]></query>
