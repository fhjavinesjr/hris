<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="hazarddutyreport" language="java" pageWidth="1230" pageHeight="900" orientation="Landscape" columnWidth="1210" leftMargin="10" rightMargin="10" topMargin="10" bottomMargin="10" uuid="6cf5cfbb-767b-43af-b1a8-6e93071df642">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="SALARY_PERIOD_KEY" class="java.lang.String"/>
	<parameter name="EARNING_TYPE_ID" class="java.lang.String"/>
	<parameter name="EARNING_TYPE_NAME" class="java.lang.String"/>
	<parameter name="EARNING_TYPE_CODE" class="java.lang.String"/>
	<parameter name="CATEGORY" class="java.lang.String"/>
	<parameter name="CURRENT_COMPANY" class="java.lang.String"/>
	<parameter name="REPORT_PERIOD_LABEL" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    CAST(ROW_NUMBER() OVER (ORDER BY pd.employeeName, pd.employeeNo) AS int) AS no,
    pd.employeeNo AS employeeNo,
    pd.employeeName AS fullname,
    ISNULL(pd.department, '') AS department,
    pd.salaryGrade AS salaryGrade,
    pd.salaryStep AS salaryStep,
    pd.basicPerSalary AS basicPerSalary,
    CAST(SUM(ISNULL(pde.amount, 0)) AS float) AS grossAmount,
    CAST(0 AS float) AS tax,
    CAST(SUM(ISNULL(pde.amount, 0)) AS float) AS netAmount,
    ISNULL(pd.department, '') AS position,
    pd.basicPerSalary AS salaryMo
FROM payroll_detail pd
INNER JOIN payroll_detail_earning pde ON pde.payroll_detail_id = pd.id
WHERE pd.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
  AND (
        UPPER(LTRIM(RTRIM(ISNULL(pde.earningCode, '')))) = UPPER(LTRIM(RTRIM(ISNULL($P{EARNING_TYPE_CODE}, ''))))
        OR UPPER(LTRIM(RTRIM(ISNULL(pde.earningName, '')))) = UPPER(LTRIM(RTRIM(ISNULL($P{EARNING_TYPE_NAME}, ''))))
      )
GROUP BY
    pd.employeeNo,
    pd.employeeName,
    pd.department,
    pd.salaryGrade,
    pd.salaryStep,
    pd.basicPerSalary
ORDER BY pd.employeeName, pd.employeeNo]]></query>
	<field name="no" class="java.lang.Integer"/>
	<field name="employeeNo" class="java.lang.String"/>
	<field name="fullname" class="java.lang.String"/>
	<field name="department" class="java.lang.String"/>
	<field name="salaryGrade" class="java.lang.Integer"/>
	<field name="salaryStep" class="java.lang.Integer"/>
	<field name="basicPerSalary" class="java.lang.Double"/>
	<field name="grossAmount" class="java.lang.Double"/>
	<field name="tax" class="java.lang.Double"/>
	<field name="netAmount" class="java.lang.Double"/>
	<field name="position" class="java.lang.String"/>
	<field name="salaryMo" class="java.lang.Double"/>
	<variable name="TOTAL_AMOUNT" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{grossAmount}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_NET" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{netAmount}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
