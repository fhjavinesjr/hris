<jasperReport name="Test" language="java" pageWidth="595" pageHeight="985" columnWidth="570" leftMargin="5" rightMargin="20" topMargin="20" bottomMargin="20" uuid="3ffc7c7b-e40f-48be-bfd4-d7f92897ec0d">
	<property name="ireport.zoom" value="1.1000000000000032"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="salaryPeriodKey" class="java.lang.String"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="salaryDate" class="java.lang.String"/>
	<parameter name="companyPhilhealthNo" class="java.lang.String"/>
	<parameter name="preparedBy" class="java.lang.String"/>
	<parameter name="preparedByEmployeeNo" class="java.lang.String"/>
	<parameter name="certifiedBy" class="java.lang.String"/>
	<parameter name="certifiedByEmployeeNo" class="java.lang.String"/>
	<query language="SQL"><![CDATA[WITH remittance_lines AS (
    SELECT
        pd.employeeNo,
        pd.employeeName,
        SUM(COALESCE(pdd.amount, 0)) AS ps,
        SUM(COALESCE(pdd.employerShare, 0)) AS es
    FROM payroll_detail pd
    INNER JOIN payroll_detail_deduction pdd ON pdd.payroll_detail_id = pd.id
    WHERE pd.salaryPeriodKey = $P{salaryPeriodKey}
      AND (
             UPPER(LTRIM(RTRIM(pdd.deductionCode))) IN ('PHIC','PHILHEALTH')
          OR UPPER(REPLACE(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(pdd.deductionName)), ' ', ''), '-', ''), '_', ''), '.', '')) IN ('PHIC','PHILHEALTH','PHILHEALTHPREMIUM','PHILHEALTHCONTRIBUTION')
      )
    GROUP BY pd.employeeNo, pd.employeeName

    UNION ALL

    SELECT
        ah.employeeNo,
        ah.employeeName,
        SUM(COALESCE(al.amount, 0)) AS ps,
        CAST(0 AS FLOAT) AS es
    FROM payroll_adjustment_header ah
    INNER JOIN payroll_adjustment_line al ON al.header_id = ah.id
    WHERE ah.salaryPeriodKey = $P{salaryPeriodKey}
      AND al.type = 'DEDUCTION'
      AND (
             UPPER(LTRIM(RTRIM(al.code))) IN ('PHIC','PHILHEALTH','PHIC_CASCADE')
          OR UPPER(REPLACE(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(al.name)), ' ', ''), '-', ''), '_', ''), '.', '')) IN ('PHIC','PHILHEALTH','PHILHEALTHPREMIUM','PHILHEALTHCONTRIBUTION','PHICCASCADE')
      )
      AND (
              ah.status = 'POSTED'
           OR (ah.status = 'PENDING' AND NOT EXISTS (
                SELECT 1 FROM payroll_period_lock ppl WHERE ppl.salaryPeriodKey = ah.salaryPeriodKey
              ))
        )
    GROUP BY ah.employeeNo, ah.employeeName
), grouped AS (
    SELECT employeeNo, employeeName, SUM(ps) AS ps, SUM(es) AS es
    FROM remittance_lines
    GROUP BY employeeNo, employeeName
), signatory_positions AS (
    SELECT
        ISNULL(prep.position, '') AS preparedByPositionResolved,
        ISNULL(cert.position, '') AS certifiedByPositionResolved
    FROM (SELECT 1 AS oneRow) oneRow
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1
                ea0.jobPositionId,
                ea0.assumptionToDutyDate,
                ea0.activeAppointment,
                ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY
                CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                ea0.assumptionToDutyDate DESC,
                ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{salaryPeriodKey}
        WHERE (
            e.employeeNo = $P{preparedByEmployeeNo}
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(ISNULL(pd.employeeName, ''))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{preparedBy})), ' ', ''), '.', ''), '-', ''))
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(CONCAT(ISNULL(e.firstname, ''), ' ', ISNULL(e.lastname, '')))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{preparedBy})), ' ', ''), '.', ''), '-', ''))
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(CONCAT(ISNULL(e.lastname, ''), ' ', ISNULL(e.firstname, '')))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{preparedBy})), ' ', ''), '.', ''), '-', ''))
        )
    ) prep
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1
                ea0.jobPositionId,
                ea0.assumptionToDutyDate,
                ea0.activeAppointment,
                ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY
                CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                ea0.assumptionToDutyDate DESC,
                ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{salaryPeriodKey}
        WHERE (
            e.employeeNo = $P{certifiedByEmployeeNo}
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(ISNULL(pd.employeeName, ''))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(CONCAT(ISNULL(e.firstname, ''), ' ', ISNULL(e.lastname, '')))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
            OR UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM(CONCAT(ISNULL(e.lastname, ''), ' ', ISNULL(e.firstname, '')))), ' ', ''), '.', ''), '-', '')) = UPPER(REPLACE(REPLACE(REPLACE(LTRIM(RTRIM($P{certifiedBy})), ' ', ''), '.', ''), '-', ''))
        )
    ) cert
)
SELECT
    CAST(ROW_NUMBER() OVER (ORDER BY ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName), ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '')) AS INT) AS no,
    CONCAT(
        ISNULL(NULLIF(LTRIM(RTRIM(per.philhealthNo)), ''), ''),
        CASE WHEN NULLIF(LTRIM(RTRIM(per.philhealthNo)), '') IS NULL THEN '' ELSE ' - ' END,
        ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName),
        CASE WHEN NULLIF(LTRIM(RTRIM(per.firstname)), '') IS NULL THEN '' ELSE ', ' + LTRIM(RTRIM(per.firstname)) END,
        CASE WHEN NULLIF(LTRIM(RTRIM(per.middlename)), '') IS NULL THEN '' ELSE ' ' + LTRIM(RTRIM(per.middlename)) END
    ) AS employee,
    CAST(COALESCE(ps,0) AS FLOAT) AS ps,
    CAST(COALESCE(es,0) AS FLOAT) AS es,
    sp.preparedByPositionResolved,
    sp.certifiedByPositionResolved
FROM grouped
CROSS JOIN signatory_positions sp
LEFT JOIN employee emp ON emp.employeeNo = grouped.employeeNo
LEFT JOIN personaldata per ON per.employeeId = emp.employeeId
WHERE COALESCE(ps,0) <> 0 OR COALESCE(es,0) <> 0
ORDER BY ISNULL(NULLIF(LTRIM(RTRIM(per.surname)), ''), grouped.employeeName), ISNULL(NULLIF(LTRIM(RTRIM(per.firstname)), ''), '')]]></query>
	<field name="no" class="java.lang.Integer"/>
	<field name="employee" class="java.lang.String"/>
	<field name="ps" class="java.lang.Double"/>
	<field name="es" class="java.lang.Double"/>
	<field name="preparedByPositionResolved" class="java.lang.String"/>
	<field name="certifiedByPositionResolved" class="java.lang.String"/>
	<variable name="psTotal" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[Math.round($F{ps} * 100.0) / 100.0]]></expression>
	</variable>
	<variable name="esTotal" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[Math.round($F{es} * 100.0) / 100.0]]></expression>
	</variable>
