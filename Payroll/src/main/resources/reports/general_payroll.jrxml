<!-- SQL-only dynamic General Payroll Register for ISOFT HRIS. Dynamic earnings/deductions are rendered as multiline breakdowns so no earning/deduction is lost to a limited Other column. -->
<jasperReport name="general_payroll" language="java" pageWidth="1230" pageHeight="900" columnWidth="1223" leftMargin="5" rightMargin="2" topMargin="5" bottomMargin="5" uuid="9b7e3792-e1af-4e0f-a346-3d1db14a5cc2">
	<property name="net.sf.jasperreports.compiler.xml.parser.validation" value="false"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="salaryPeriodKey" class="java.lang.String"/>
	<parameter name="currentCompany" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA["ISOFT HRIS"]]></defaultValueExpression>
	</parameter>
	<parameter name="preparedBy" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="approvedBy" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="cashierBy" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH base AS (
    SELECT
        pd.id,
        pd.employeeNo,
        pd.employeeName,
        pd.department,
        pd.salaryGrade,
        pd.salaryStep,
        pd.salaryPeriodKey,
        pd.cutoffStartDate,
        pd.cutoffEndDate,
        pd.salaryDate,
        pd.actualBasic,
        pd.grossAmount AS computedGrossAmount,
        pd.totalDeduction AS computedTotalDeduction,
        pd.netAmount AS computedNetAmount,
        pd.displayToLastPage,
        ROW_NUMBER() OVER (
            ORDER BY
                CASE WHEN ISNULL(pd.displayToLastPage, 0) = 1 THEN 1 ELSE 0 END,
                ISNULL(pd.department, ''),
                pd.employeeName,
                pd.employeeNo
        ) AS rowNo
    FROM payroll_detail pd
    WHERE pd.salaryPeriodKey = $P{salaryPeriodKey}
      AND ISNULL(CAST(pd.status AS varchar(30)), 'COMPUTED') <> 'CANCELLED'
),
base_earnings AS (
    SELECT
        b.employeeNo,
        pde.earningCode AS code,
        pde.earningName AS displayName,
        ISNULL(pde.indexNo, 0) AS indexNo,
        SUM(ISNULL(pde.amount, 0)) AS amount
    FROM base b
    INNER JOIN payroll_detail_earning pde ON pde.payroll_detail_id = b.id
    GROUP BY b.employeeNo, pde.earningCode, pde.earningName, ISNULL(pde.indexNo, 0)
),
adjustment_earnings AS (
    SELECT
        pah.employeeNo,
        pal.code,
        CONCAT(
            pal.name,
            ' [ADJ-', UPPER(ISNULL(pah.status, '')), 
            CASE WHEN ISNULL(pah.authorityNo, '') <> '' THEN CONCAT(' / ', pah.authorityNo) ELSE '' END,
            ']'
        ) AS displayName,
        9000 + ISNULL(pal.indexNo, 0) AS indexNo,
        SUM(ISNULL(pal.amount, 0)) AS amount
    FROM payroll_adjustment_header pah
    INNER JOIN payroll_adjustment_line pal ON pal.header_id = pah.id
    WHERE pah.salaryPeriodKey = $P{salaryPeriodKey}
      AND (
            UPPER(ISNULL(pah.status, '')) = 'POSTED'
            OR (
                UPPER(ISNULL(pah.status, '')) = 'PENDING'
                AND NOT EXISTS (
                    SELECT 1
                    FROM payroll_period_lock ppl
                    WHERE ppl.salaryPeriodKey = $P{salaryPeriodKey}
                )
            )
      )
      AND UPPER(ISNULL(pal.type, '')) = 'EARNING'
    GROUP BY pah.employeeNo, pal.code, pal.name, UPPER(ISNULL(pah.status, '')), pah.authorityNo, ISNULL(pal.indexNo, 0)
),
earning_source AS (
    SELECT * FROM base_earnings
    UNION ALL
    SELECT * FROM adjustment_earnings
),
earning_lines AS (
    SELECT
        employeeNo,
        STRING_AGG(
            CAST(CONCAT(displayName, ' [', code, ']: ', CONVERT(varchar(50), CAST(amount AS money), 1)) AS varchar(max)),
            CHAR(10)
        ) WITHIN GROUP (ORDER BY indexNo, displayName, code) AS earningBreakdown,
        SUM(amount) AS grossAmount
    FROM earning_source
    GROUP BY employeeNo
),
base_deductions AS (
    SELECT
        b.employeeNo,
        pdd.deductionCode AS code,
        pdd.deductionName AS displayName,
        ISNULL(pdd.indexNo, 0) AS indexNo,
        SUM(ISNULL(pdd.amount, 0)) AS amount
    FROM base b
    INNER JOIN payroll_detail_deduction pdd ON pdd.payroll_detail_id = b.id
    GROUP BY b.employeeNo, pdd.deductionCode, pdd.deductionName, ISNULL(pdd.indexNo, 0)
),
adjustment_deductions AS (
    SELECT
        pah.employeeNo,
        pal.code,
        CONCAT(
            pal.name,
            ' [ADJ-', UPPER(ISNULL(pah.status, '')), 
            CASE WHEN ISNULL(pah.authorityNo, '') <> '' THEN CONCAT(' / ', pah.authorityNo) ELSE '' END,
            ']'
        ) AS displayName,
        9000 + ISNULL(pal.indexNo, 0) AS indexNo,
        SUM(ISNULL(pal.amount, 0)) AS amount
    FROM payroll_adjustment_header pah
    INNER JOIN payroll_adjustment_line pal ON pal.header_id = pah.id
    WHERE pah.salaryPeriodKey = $P{salaryPeriodKey}
      AND (
            UPPER(ISNULL(pah.status, '')) = 'POSTED'
            OR (
                UPPER(ISNULL(pah.status, '')) = 'PENDING'
                AND NOT EXISTS (
                    SELECT 1
                    FROM payroll_period_lock ppl
                    WHERE ppl.salaryPeriodKey = $P{salaryPeriodKey}
                )
            )
      )
      AND UPPER(ISNULL(pal.type, '')) = 'DEDUCTION'
    GROUP BY pah.employeeNo, pal.code, pal.name, UPPER(ISNULL(pah.status, '')), pah.authorityNo, ISNULL(pal.indexNo, 0)
),
deduction_source AS (
    SELECT * FROM base_deductions
    UNION ALL
    SELECT * FROM adjustment_deductions
),
deduction_lines AS (
    SELECT
        employeeNo,
        STRING_AGG(
            CAST(CONCAT(displayName, ' [', code, ']: ', CONVERT(varchar(50), CAST(amount AS money), 1)) AS varchar(max)),
            CHAR(10)
        ) WITHIN GROUP (ORDER BY indexNo, displayName, code) AS deductionBreakdown,
        SUM(amount) AS totalDeduction
    FROM deduction_source
    GROUP BY employeeNo
),
grand_earnings AS (
    SELECT STRING_AGG(
        CAST(CONCAT(displayName, ' [', code, ']: ', CONVERT(varchar(50), CAST(amount AS money), 1)) AS varchar(max)),
        CHAR(10)
    ) WITHIN GROUP (ORDER BY indexNo, displayName, code) AS grandEarningsBreakdown
    FROM (
        SELECT code, displayName, MIN(indexNo) AS indexNo, SUM(amount) AS amount
        FROM earning_source
        GROUP BY code, displayName
    ) x
),
grand_deductions AS (
    SELECT STRING_AGG(
        CAST(CONCAT(displayName, ' [', code, ']: ', CONVERT(varchar(50), CAST(amount AS money), 1)) AS varchar(max)),
        CHAR(10)
    ) WITHIN GROUP (ORDER BY indexNo, displayName, code) AS grandDeductionsBreakdown
    FROM (
        SELECT code, displayName, MIN(indexNo) AS indexNo, SUM(amount) AS amount
        FROM deduction_source
        GROUP BY code, displayName
    ) x
),
final_rows AS (
    SELECT
        b.*,
        ISNULL(el.earningBreakdown, '') AS earningBreakdown,
        ISNULL(el.grossAmount, 0) AS grossAmount,
        ISNULL(dl.deductionBreakdown, '') AS deductionBreakdown,
        ISNULL(dl.totalDeduction, 0) AS totalDeduction,
        ISNULL(el.grossAmount, 0) - ISNULL(dl.totalDeduction, 0) AS netAmount
    FROM base b
    LEFT JOIN earning_lines el ON el.employeeNo = b.employeeNo
    LEFT JOIN deduction_lines dl ON dl.employeeNo = b.employeeNo
)
SELECT
    fr.rowNo,
    fr.employeeNo,
    fr.employeeName,
    fr.department,
    fr.salaryGrade,
    fr.salaryStep,
    fr.salaryPeriodKey,
    fr.cutoffStartDate,
    fr.cutoffEndDate,
    fr.salaryDate,
    fr.actualBasic,
    fr.earningBreakdown,
    fr.grossAmount,
    fr.deductionBreakdown,
    fr.totalDeduction,
    fr.netAmount,
    SUM(fr.actualBasic) OVER () AS grandActualBasic,
    SUM(fr.grossAmount) OVER () AS grandGrossAmount,
    SUM(fr.totalDeduction) OVER () AS grandTotalDeduction,
    SUM(fr.netAmount) OVER () AS grandNetAmount,
    ISNULL(ge.grandEarningsBreakdown, '') AS grandEarningsBreakdown,
    ISNULL(gd.grandDeductionsBreakdown, '') AS grandDeductionsBreakdown,
    CASE WHEN EXISTS (
        SELECT 1
        FROM payroll_period_lock ppl
        WHERE ppl.salaryPeriodKey = $P{salaryPeriodKey}
    )
    THEN 'FINAL / LOCKED - POSTED ADJUSTMENTS ONLY'
    ELSE 'DRAFT / PREVIEW - POSTED + PENDING ADJUSTMENTS INCLUDED'
    END AS reportMode
FROM final_rows fr
CROSS JOIN grand_earnings ge
CROSS JOIN grand_deductions gd
ORDER BY fr.rowNo]]></query>
	<field name="rowNo" class="java.lang.Integer"/>
	<field name="employeeNo" class="java.lang.String"/>
	<field name="employeeName" class="java.lang.String"/>
	<field name="department" class="java.lang.String"/>
	<field name="salaryGrade" class="java.lang.Integer"/>
	<field name="salaryStep" class="java.lang.Integer"/>
	<field name="salaryPeriodKey" class="java.lang.String"/>
	<field name="cutoffStartDate" class="java.sql.Date"/>
	<field name="cutoffEndDate" class="java.sql.Date"/>
	<field name="salaryDate" class="java.sql.Date"/>
	<field name="actualBasic" class="java.lang.Double"/>
	<field name="earningBreakdown" class="java.lang.String"/>
	<field name="grossAmount" class="java.lang.Double"/>
	<field name="deductionBreakdown" class="java.lang.String"/>
	<field name="totalDeduction" class="java.lang.Double"/>
	<field name="netAmount" class="java.lang.Double"/>
	<field name="grandActualBasic" class="java.lang.Double"/>
	<field name="grandGrossAmount" class="java.lang.Double"/>
	<field name="grandTotalDeduction" class="java.lang.Double"/>
	<field name="grandNetAmount" class="java.lang.Double"/>
	<field name="grandEarningsBreakdown" class="java.lang.String"/>
	<field name="grandDeductionsBreakdown" class="java.lang.String"/>
	<field name="reportMode" class="java.lang.String"/>
	<group name="PayrollHeader" reprintHeaderOnEachPage="true">
		<expression><![CDATA["ALL"]]></expression>
		<groupHeader>
			<band height="86">
				<element kind="textField" uuid="37b242d0-57d6-4c83-969c-a0af9b552d8d" x="0" y="0" width="1223" height="18" fontName="Arial" fontSize="10.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
					<expression><![CDATA[($P{currentCompany} == null || $P{currentCompany}.trim().isEmpty()) ? "ISOFT HRIS" : $P{currentCompany}]]></expression>
					<box><pen lineWidth="0.25"/></box>
				</element>
				<element kind="textField" uuid="17305bfc-bc5c-4ceb-9f33-288dd6a28926" x="0" y="18" width="1223" height="16" fontName="Arial" fontSize="8.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
					<expression><![CDATA["GENERAL PAYROLL REGISTER - " + $P{salaryPeriodKey} + "  |  " + $F{reportMode}]]></expression>
					<box><pen lineWidth="0.25"/></box>
				</element>
				<element kind="textField" uuid="40955eac-d8b5-4ed5-9e2e-ded8a11a6949" x="0" y="34" width="1223" height="14" fontName="Arial" fontSize="7.0" hTextAlign="Center" vTextAlign="Middle">
					<expression><![CDATA["Cut-off: " + new java.text.SimpleDateFormat("MMM dd, yyyy").format($F{cutoffStartDate}) + " to " + new java.text.SimpleDateFormat("MMM dd, yyyy").format($F{cutoffEndDate}) + "    Salary Date: " + (($F{salaryDate} == null) ? "" : new java.text.SimpleDateFormat("MMM dd, yyyy").format($F{salaryDate}))]]></expression>
					<box><pen lineWidth="0.25"/></box>
				</element>
				<element kind="staticText" uuid="bfc5e890-3384-49d9-a7de-88c6143666b4" mode="Opaque" x="0" y="50" width="25" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[No]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="711e84d7-3374-453e-a82c-53f06c577663" mode="Opaque" x="25" y="50" width="150" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[Employee]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="c924018e-a2a1-49c3-b058-9507d8c389ac" mode="Opaque" x="175" y="50" width="95" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[Office]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="6bb5b1b8-983b-4313-a776-c66364ec3f72" mode="Opaque" x="270" y="50" width="30" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[SG/SS]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="6da19c3e-4326-4d3a-bb51-e21c3fe2e72f" mode="Opaque" x="300" y="50" width="65" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[Basic]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="9ab353f0-29c6-4749-86a6-4504daeaef65" mode="Opaque" x="365" y="50" width="280" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[Earnings + Adjustments (dynamic)]]></text><box><pen lineWidth="0.25"/></box></element>
