				<element kind="textField" uuid="7dab871a-d31a-4745-8968-ec62e7886026" x="300" y="0" width="65" height="22" fontName="Arial" fontSize="6.0" pattern="#,##0.00" bold="true" hTextAlign="Right" vTextAlign="Middle"><expression><![CDATA[$F{grandActualBasic}]]></expression><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="926a0a5e-ddba-477a-a5fc-3f6c840f8beb" mode="Opaque" x="365" y="0" width="280" height="22" backcolor="#E8E8E8" fontName="Arial" fontSize="7.0" bold="true" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[TOTAL GROSS]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="textField" uuid="72ddcc1e-ef48-4f11-9131-d884c1f79d15" x="645" y="0" width="70" height="22" fontName="Arial" fontSize="6.0" pattern="#,##0.00" bold="true" hTextAlign="Right" vTextAlign="Middle"><expression><![CDATA[$F{grandGrossAmount}]]></expression><box><pen lineWidth="0.25"/></box></element>
