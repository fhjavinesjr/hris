	<detail>
		<band height="44" splitType="Stretch">
			<element kind="textField" uuid="ef67800b-4b40-4357-a292-5326bdeed5e2" x="0" y="0" width="25" height="44" fontName="Arial" fontSize="5.5" stretchType="ContainerHeight" hTextAlign="Center" vTextAlign="Top"><expression><![CDATA[$F{rowNo}]]></expression><box><pen lineWidth="0.25"/></box></element>
			<element kind="textField" uuid="ae3f6045-427a-41b1-b34c-48619f1f0338" x="25" y="0" width="150" height="44" fontName="Arial" fontSize="5.5" textAdjust="StretchHeight" stretchType="ContainerHeight" hTextAlign="Left" vTextAlign="Top"><expression><![CDATA[$F{employeeName} + "\n" + $F{employeeNo}]]></expression><box><pen lineWidth="0.25"/></box></element>
			<element kind="textField" uuid="d301d6bd-ed49-488b-8d31-004f344a1e45" x="175" y="0" width="95" height="44" fontName="Arial" fontSize="5.5" textAdjust="StretchHeight" stretchType="ContainerHeight" hTextAlign="Left" vTextAlign="Top"><expression><![CDATA[$F{department}]]></expression><box><pen lineWidth="0.25"/></box></element>
