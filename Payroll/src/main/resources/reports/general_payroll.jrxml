				<element kind="staticText" uuid="c5459e5d-7f4c-410e-a3df-446d9e672bdc" mode="Opaque" x="715" y="50" width="360" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[Deductions / Loans / Adjustments (dynamic)]]></text><box><pen lineWidth="0.25"/></box></element>
				<element kind="staticText" uuid="92a59488-e443-44da-b4d6-7a0c5944c17a" mode="Opaque" x="1075" y="50" width="70" height="34" backcolor="#E8E8E8" fontName="Arial" fontSize="6.0" bold="true" hTextAlign="Center" vTextAlign="Middle"><text><![CDATA[Total Deduct]]></text><box><pen lineWidth="0.25"/></box></element>
