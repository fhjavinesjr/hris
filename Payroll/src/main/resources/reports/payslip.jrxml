<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="payslip_dynamic" language="java" pageWidth="780" pageHeight="842" columnWidth="740" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f90f61ce-d3dc-4fee-bff8-2a8dbb34c17a">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="employeeNo" class="java.lang.String"/>
	<parameter name="salaryPeriodKey" class="java.lang.String"/>
	<parameter name="releasedOnly" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[0]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH selected_detail AS (
    SELECT TOP 1 pd.*
    FROM payroll_detail pd
    WHERE pd.employeeNo = $P{employeeNo}
      AND pd.salaryPeriodKey = $P{salaryPeriodKey}
      AND ($P{releasedOnly} = 0 OR pd.isLocked = 1)
    ORDER BY pd.id DESC
),
adjustment_summary AS (
    SELECT
        h.employeeNo,
        h.salaryPeriodKey,
        SUM(CASE
            WHEN UPPER(COALESCE(l.type, '')) = 'EARNING' THEN COALESCE(l.amount, 0)
            WHEN UPPER(COALESCE(l.type, '')) = 'DEDUCTION' THEN -COALESCE(l.amount, 0)
            ELSE 0
        END) AS netAdjustment
    FROM payroll_adjustment_header h
    INNER JOIN payroll_adjustment_line l ON l.header_id = h.id
    INNER JOIN selected_detail pd
        ON pd.employeeNo = h.employeeNo
       AND pd.salaryPeriodKey = h.salaryPeriodKey
    WHERE UPPER(COALESCE(h.status, '')) = 'POSTED'
    GROUP BY h.employeeNo, h.salaryPeriodKey
),
raw_lines AS (
    SELECT
        'EARNINGS' AS lineSection,
        COALESCE(e.earningCode, '') AS lineCode,
        COALESCE(e.earningName, '') AS lineName,
        COALESCE(e.amount, 0) AS lineAmount,
        CAST(NULL AS float) AS employerShare,
        CAST('' AS varchar(100)) AS referenceNo,
        CAST('' AS varchar(50)) AS termPaid,
        10 + COALESCE(e.indexNo, 0) AS sortNo
    FROM payroll_detail_earning e
    INNER JOIN selected_detail pd ON pd.id = e.payroll_detail_id

    UNION ALL

    SELECT
        'DEDUCTIONS' AS lineSection,
        COALESCE(d.deductionCode, '') AS lineCode,
        COALESCE(d.deductionName, '') AS lineName,
        COALESCE(d.amount, 0) AS lineAmount,
        COALESCE(d.employerShare, 0) AS employerShare,
        COALESCE(d.reference, '') AS referenceNo,
        CASE
            WHEN d.loanPaymentsMade IS NOT NULL AND d.loanTotalAmount IS NOT NULL
                THEN CONCAT(CAST(d.loanPaymentsMade AS varchar(20)), ' paid')
            WHEN d.loanPaymentsMade IS NOT NULL
                THEN CAST(d.loanPaymentsMade AS varchar(20))
            ELSE ''
        END AS termPaid,
        100 + COALESCE(d.indexNo, 0) AS sortNo
    FROM payroll_detail_deduction d
    INNER JOIN selected_detail pd ON pd.id = d.payroll_detail_id

    UNION ALL

    SELECT
        'POSTED ADJUSTMENTS' AS lineSection,
        COALESCE(l.code, '') AS lineCode,
        COALESCE(l.name, '') AS lineName,
        CASE
            WHEN UPPER(COALESCE(l.type, '')) = 'EARNING' THEN COALESCE(l.amount, 0)
            WHEN UPPER(COALESCE(l.type, '')) = 'DEDUCTION' THEN -COALESCE(l.amount, 0)
            ELSE COALESCE(l.amount, 0)
        END AS lineAmount,
        CAST(NULL AS float) AS employerShare,
        COALESCE(h.authorityNo, '') AS referenceNo,
        COALESCE(h.status, '') AS termPaid,
        300 + COALESCE(l.indexNo, 0) AS sortNo
    FROM payroll_adjustment_header h
    INNER JOIN payroll_adjustment_line l ON l.header_id = h.id
    INNER JOIN selected_detail pd
        ON pd.employeeNo = h.employeeNo
       AND pd.salaryPeriodKey = h.salaryPeriodKey
    WHERE UPPER(COALESCE(h.status, '')) = 'POSTED'
),
lines AS (
    SELECT
        lineSection,
        lineCode,
        lineName,
        SUM(lineAmount) AS lineAmount,
        SUM(COALESCE(employerShare, 0)) AS employerShare,
        MAX(referenceNo) AS referenceNo,
        MAX(termPaid) AS termPaid,
        MIN(sortNo) AS sortNo
    FROM raw_lines
    GROUP BY lineSection, lineCode, lineName
),
final_lines AS (
    SELECT * FROM lines
    UNION ALL
    SELECT 'PAYSLIP DETAILS', '', 'No earnings or deductions found for this payroll record.', 0, 0, '', '', 999
    WHERE NOT EXISTS (SELECT 1 FROM lines)
)
SELECT
    pd.employeeNo,
    pd.employeeName,
    COALESCE(pd.department, '') AS department,
    pd.salaryGrade,
    pd.salaryStep,
    pd.salaryPeriodKey,
    pd.cutoffStartDate,
    pd.cutoffEndDate,
    pd.salaryDate,
    pd.basicPerSalary,
    pd.salaryPerDay,
    pd.salaryPerMinute,
    pd.actualBasic,
    pd.grossAmount,
    pd.totalDeduction,
    pd.netAmount,
    COALESCE(adj.netAdjustment, 0) AS netAdjustment,
    COALESCE(pd.netAmount, 0) + COALESCE(adj.netAdjustment, 0) AS finalNetPay,
    pd.taxableIncome,
    pd.taxAmount,
    pd.lateMinutes,
    pd.lateValue,
    pd.undertimeMinutes,
    pd.undertimeValue,
    pd.absentDays,
    pd.absentParticulars,
    pd.vacationLeaveUsed,
    pd.sickLeaveUsed,
    pd.forceLeaveUsed,
    pd.vlBalance,
    pd.slBalance,
    pd.status,
    pd.isLocked,
    fl.lineSection,
    fl.lineCode,
    fl.lineName,
    fl.lineAmount,
    fl.employerShare,
    fl.referenceNo,
    fl.termPaid,
    fl.sortNo
FROM selected_detail pd
LEFT JOIN adjustment_summary adj
    ON adj.employeeNo = pd.employeeNo
   AND adj.salaryPeriodKey = pd.salaryPeriodKey
CROSS JOIN final_lines fl
ORDER BY
    CASE fl.lineSection
        WHEN 'EARNINGS' THEN 1
        WHEN 'DEDUCTIONS' THEN 2
        WHEN 'POSTED ADJUSTMENTS' THEN 3
        ELSE 9
    END,
    fl.sortNo,
    fl.lineName;]]></query>
