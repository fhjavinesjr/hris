		<element kind="textField" uuid="dedcb7c0-9387-40b8-b5f5-b7284058eab5" x="610" y="87" width="115" height="12" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right">
			<expression><![CDATA[$F{netAdjustment}]]></expression>
