<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="generic_payroll_deduction" language="java" pageWidth="1230" pageHeight="900" orientation="Landscape" columnWidth="1210" leftMargin="10" rightMargin="10" topMargin="10" bottomMargin="10" uuid="98ad3be0-9bf5-488e-8358-110a5dbf4f18">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="SALARY_PERIOD_KEY" class="java.lang.String"/>
	<parameter name="DEDUCTION_TYPE_ID" class="java.lang.String"/>
	<parameter name="DEDUCTION_TYPE_NAME" class="java.lang.String"/>
	<parameter name="DEDUCTION_TYPE_CODE" class="java.lang.String"/>
	<parameter name="CURRENT_COMPANY" class="java.lang.String"/>
	<parameter name="REPORT_PERIOD_LABEL" class="java.lang.String"/>
	<parameter name="PREPARED_BY" class="java.lang.String"/>
	<parameter name="PREPARED_BY_EMPLOYEE_NO" class="java.lang.String"/>
	<parameter name="CERTIFIED_BY" class="java.lang.String"/>
	<parameter name="CERTIFIED_BY_EMPLOYEE_NO" class="java.lang.String"/>
	<parameter name="APPROVED_BY" class="java.lang.String"/>
	<parameter name="APPROVED_BY_EMPLOYEE_NO" class="java.lang.String"/>
	<query language="SQL"><![CDATA[WITH lock_state AS (
    SELECT CASE
        WHEN EXISTS (
            SELECT 1
            FROM payroll_period_lock ppl
            WHERE ppl.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
        ) THEN 1 ELSE 0
    END AS isLocked
), filter_values AS (
    SELECT
        UPPER(LTRIM(RTRIM(ISNULL($P{DEDUCTION_TYPE_CODE}, '')))) AS rawCode,
        UPPER(LTRIM(RTRIM(ISNULL($P{DEDUCTION_TYPE_NAME}, '')))) AS rawName,
        REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL($P{DEDUCTION_TYPE_CODE}, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') AS normCode,
        REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL($P{DEDUCTION_TYPE_NAME}, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') AS normName
), report_lines AS (
    -- Original computed deduction lines from payroll computation.
    SELECT
        pd.employeeNo,
        pd.employeeName,
        ISNULL(pd.department, '') AS department,
        pd.salaryGrade,
        pd.salaryStep,
        pd.basicPerSalary,
        ISNULL(pdd.amount, 0) AS amount,
        ISNULL(pdd.employerShare, 0) AS employerShare,
        ISNULL(pdd.reference, '') AS referenceNo,
        pdd.loanTotalAmount,
        pdd.loanPaymentsMade
    FROM payroll_detail pd
    INNER JOIN payroll_detail_deduction pdd ON pdd.payroll_detail_id = pd.id
    CROSS JOIN filter_values fv
    WHERE pd.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
      AND (
            REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pdd.deductionCode, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN (fv.normCode, fv.normName)
            OR REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pdd.deductionName, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN (fv.normCode, fv.normName)
            OR (fv.normCode = 'PHIC' AND REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pdd.deductionName, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN ('PHILHEALTH', 'PHILHEALTHCONTRIBUTION'))
            OR (fv.normCode = 'HDMF' AND REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pdd.deductionName, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN ('PAGIBIG', 'PAGIBIGCONTRIBUTION'))
            OR (fv.normCode = 'WTX' AND REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pdd.deductionName, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN ('WITHHOLDINGTAX', 'BIRWITHHOLDINGTAX'))
          )

    UNION ALL

    -- Deduction adjustments for the same deduction/loan type.
    -- Draft/unlocked report includes POSTED + PENDING.
    -- Final/locked report includes POSTED only.
    SELECT
        pd.employeeNo,
        pd.employeeName,
        ISNULL(pd.department, '') AS department,
        pd.salaryGrade,
        pd.salaryStep,
        pd.basicPerSalary,
        ABS(ISNULL(pal.amount, 0)) AS amount,
        CAST(0 AS float) AS employerShare,
        ISNULL(pah.authorityNo, '') AS referenceNo,
        CAST(NULL AS float) AS loanTotalAmount,
        CAST(NULL AS int) AS loanPaymentsMade
    FROM payroll_detail pd
    INNER JOIN payroll_adjustment_header pah
        ON pah.employeeNo = pd.employeeNo
       AND pah.salaryPeriodKey = pd.salaryPeriodKey
    INNER JOIN payroll_adjustment_line pal
        ON pal.header_id = pah.id
    CROSS JOIN lock_state ls
    CROSS JOIN filter_values fv
    WHERE pd.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
      AND UPPER(LTRIM(RTRIM(ISNULL(pal.type, '')))) = 'DEDUCTION'
      AND (
            (ls.isLocked = 1 AND UPPER(LTRIM(RTRIM(ISNULL(pah.status, '')))) = 'POSTED')
            OR
            (ls.isLocked = 0 AND UPPER(LTRIM(RTRIM(ISNULL(pah.status, '')))) IN ('POSTED', 'PENDING'))
          )
      AND UPPER(LTRIM(RTRIM(ISNULL(pah.status, '')))) <> 'SUPERSEDED'
      AND (
            REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pal.code, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN (fv.normCode, fv.normName)
            OR REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pal.name, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN (fv.normCode, fv.normName)
            OR (fv.normCode = 'PHIC' AND REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pal.name, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN ('PHILHEALTH', 'PHILHEALTHCONTRIBUTION'))
            OR (fv.normCode = 'HDMF' AND REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pal.name, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN ('PAGIBIG', 'PAGIBIGCONTRIBUTION'))
            OR (fv.normCode = 'WTX' AND REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(UPPER(LTRIM(RTRIM(ISNULL(pal.name, '')))), ' ', ''), '-', ''), '.', ''), '/', ''), '_', '') IN ('WITHHOLDINGTAX', 'BIRWITHHOLDINGTAX'))
          )
), signatory_positions AS (
    SELECT
        ISNULL(prep.position, '') AS preparedByPosition,
        ISNULL(cert.position, '') AS certifiedByPosition,
        ISNULL(appr.position, '') AS approvedByPosition
    FROM (SELECT 1 AS oneRow) oneRow
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1 ea0.jobPositionId, ea0.assumptionToDutyDate, ea0.activeAppointment, ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                     ea0.assumptionToDutyDate DESC,
                     ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
        WHERE e.employeeNo = $P{PREPARED_BY_EMPLOYEE_NO}
    ) prep
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1 ea0.jobPositionId, ea0.assumptionToDutyDate, ea0.activeAppointment, ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                     ea0.assumptionToDutyDate DESC,
                     ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
        WHERE e.employeeNo = $P{CERTIFIED_BY_EMPLOYEE_NO}
    ) cert
    OUTER APPLY (
        SELECT TOP 1 COALESCE(jp.jobPositionName, e.position, pd.department, '') AS position
        FROM employee e
        OUTER APPLY (
            SELECT TOP 1 ea0.jobPositionId, ea0.assumptionToDutyDate, ea0.activeAppointment, ea0.employeeAppointmentId
            FROM employeeappointment ea0
            WHERE ea0.employeeId = e.employeeId
            ORDER BY CASE WHEN ISNULL(ea0.activeAppointment, 0) = 1 THEN 0 ELSE 1 END,
                     ea0.assumptionToDutyDate DESC,
                     ea0.employeeAppointmentId DESC
        ) ea
        LEFT JOIN job_position jp ON jp.jobPositionId = ea.jobPositionId
        LEFT JOIN payroll_detail pd ON pd.employeeNo = e.employeeNo AND pd.salaryPeriodKey = $P{SALARY_PERIOD_KEY}
        WHERE e.employeeNo = $P{APPROVED_BY_EMPLOYEE_NO}
    ) appr
)

SELECT
    CAST(ROW_NUMBER() OVER (ORDER BY rl.employeeName, rl.employeeNo) AS int) AS no,
    rl.employeeNo AS employeeNo,
    rl.employeeName AS fullname,
    rl.department AS department,
    rl.salaryGrade AS salaryGrade,
    rl.salaryStep AS salaryStep,
    rl.basicPerSalary AS basicPerSalary,
    CAST(SUM(ISNULL(rl.amount, 0)) AS float) AS deductionAmount,
    CAST(SUM(ISNULL(rl.employerShare, 0)) AS float) AS employerShare,
    MAX(ISNULL(rl.referenceNo, '')) AS referenceNo,
    MAX(rl.loanTotalAmount) AS loanTotalAmount,
    MAX(rl.loanPaymentsMade) AS loanPaymentsMade,
    CAST(-1 * SUM(ISNULL(rl.amount, 0)) AS float) AS netEffect,
    MAX(sp.preparedByPosition) AS preparedByPosition,
    MAX(sp.certifiedByPosition) AS certifiedByPosition,
    MAX(sp.approvedByPosition) AS approvedByPosition
FROM report_lines rl
CROSS JOIN signatory_positions sp
GROUP BY
    rl.employeeNo,
    rl.employeeName,
    rl.department,
    rl.salaryGrade,
    rl.salaryStep,
    rl.basicPerSalary
HAVING SUM(ISNULL(rl.amount, 0)) <> 0
ORDER BY rl.employeeName, rl.employeeNo]]></query>
	<field name="no" class="java.lang.Integer"/>
	<field name="employeeNo" class="java.lang.String"/>
	<field name="fullname" class="java.lang.String"/>
	<field name="department" class="java.lang.String"/>
	<field name="salaryGrade" class="java.lang.Integer"/>
	<field name="salaryStep" class="java.lang.Integer"/>
	<field name="basicPerSalary" class="java.lang.Double"/>
	<field name="deductionAmount" class="java.lang.Double"/>
	<field name="employerShare" class="java.lang.Double"/>
	<field name="referenceNo" class="java.lang.String"/>
	<field name="loanTotalAmount" class="java.lang.Double"/>
	<field name="loanPaymentsMade" class="java.lang.Integer"/>
	<field name="netEffect" class="java.lang.Double"/>
	<field name="preparedByPosition" class="java.lang.String"/>
	<field name="certifiedByPosition" class="java.lang.String"/>
	<field name="approvedByPosition" class="java.lang.String"/>
	<variable name="TOTAL_DEDUCTION" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{deductionAmount}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_EMPLOYER_SHARE" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{employerShare}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_NET_EFFECT" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{netEffect}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
