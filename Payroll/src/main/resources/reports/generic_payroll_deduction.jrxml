		<element kind="textField" uuid="fc2c1bbb-fbb7-4e9d-97de-b82d5e38d50c" x="855" y="0" width="135" height="24" fontSize="8.0" pattern="#,##0.00" bold="true" hTextAlign="Right" vTextAlign="Middle">
			<expression><![CDATA[$V{TOTAL_EMPLOYER_SHARE}]]></expression>
			<box>
				<pen lineWidth="0.5"/>
