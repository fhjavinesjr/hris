				<element kind="textField" uuid="9e16c4a7-42b0-483e-9f94-83f2323cf4e3" x="0" y="7" width="319" height="48" markup="styled" fontName="Tahoma" fontSize="8.0" pdfEmbedded="false" hTextAlign="Center">
					<printWhenExpression><![CDATA[$P{isDOH} == true]]></printWhenExpression>
					<expression><![CDATA["<style size=\"8\" isBold=\"true\">Republic of the Philippines</style><br />" +
"<style size=\"8\" isBold=\"true\">Department of Health</style><br />" +
"<style size=\"10\" isBold=\"true\"><b>" + $P{currentCompany} + "</b></style><br />" +
