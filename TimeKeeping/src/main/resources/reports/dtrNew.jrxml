<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="dtr" language="java" pageWidth="680" pageHeight="880" columnWidth="640" leftMargin="20" rightMargin="20" topMargin="0" bottomMargin="0" uuid="5f2fe1a9-3a23-441c-b3f0-7790f2b398bd" summaryWithPageHeaderAndFooter="true">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.8181818181818306"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="102"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="HRISOF SQL Server"/>
	<parameter name="fromDate" forPrompting="false" class="java.sql.Date"/>
	<parameter name="toDate" forPrompting="false" class="java.sql.Date"/>
	<parameter name="EMPLOYEE_ID" class="java.lang.String"/>
	<parameter name="currentCompany" class="java.lang.String"/>
	<parameter name="currentCompanyAddress" class="java.lang.String"/>
	<parameter name="webAppPath" class="java.lang.String"/>
	<parameter name="lastDtrDate" class="java.sql.Date"/>
	<parameter name="logoleft" class="java.lang.Object"/>
	<parameter name="logoright" class="java.lang.Object"/>
	<parameter name="isDOH" class="java.lang.Boolean"/>
	<query language="sql"><![CDATA[WITH DateRange AS (
    SELECT CAST($P{fromDate} AS date) AS work_date
    UNION ALL
    SELECT DATEADD(day, 1, work_date)
    FROM DateRange
    WHERE work_date < CAST($P{toDate} AS date)
),
EmpInfo AS (
    SELECT TOP 1
        e.employeeId,
        e.employeeNo,
        CONCAT(
            ISNULL(pd.firstname, ISNULL(e.firstname, '')),
            CASE WHEN ISNULL(pd.middlename, '') = '' THEN ' ' ELSE CONCAT(' ', pd.middlename, ' ') END,
            ISNULL(pd.surname, ISNULL(e.lastname, ''))
        ) AS fullname
    FROM employee e
    LEFT JOIN personaldata pd ON pd.employeeId = e.employeeId
    WHERE CAST(e.employeeId AS varchar(50)) = $P{EMPLOYEE_ID}
       OR e.employeeNo = $P{EMPLOYEE_ID}
),
DailyBase AS (
    SELECT
        dr.work_date AS dtrDate,
        ei.fullname,
        ISNULL(d.total_work_minutes, 0) AS regMin,
        0 AS excessMin,
        0.0 AS ndApproved,
        CAST(ISNULL(d.total_overtime_minutes, 0) / 60.0 AS float) AS otReg,
        0.0 AS otExcess,
        CAST(ISNULL(d.total_overtime_minutes, 0) / 60.0 AS float) AS otRegApproved,
        0.0 AS otExcessApproved,
        ISNULL(d.total_late_minutes, 0) AS lateMin,
        CAST((ISNULL(d.total_late_minutes, 0) + ISNULL(d.total_undertime_minutes, 0)) % 60 AS int) AS underMin,
        CASE
            WHEN UPPER(ISNULL(d.attendance_status, '')) = 'ABSENT' THEN 480
            WHEN d.dtr_daily_id IS NULL
                 AND ISNULL(ws.isDayOff, 0) = 0
                 AND la.leaveType IS NULL
                 AND ob.officialEngagementApplicationId IS NULL
                 AND cto.ctoId IS NULL
                 AND tc.timeCorrectionId IS NULL
                 AND ps.passSlipId IS NULL THEN 480
            ELSE 0
        END AS absentMin,
        CASE
            WHEN d.dtr_daily_id IS NULL AND ISNULL(ws.isDayOff, 0) = 1 THEN 'REST DAY'
            WHEN d.dtr_daily_id IS NULL AND la.leaveType IS NOT NULL THEN la.leaveType
            WHEN d.dtr_daily_id IS NULL AND ob.officialEngagementApplicationId IS NOT NULL THEN
                CASE
                    WHEN UPPER(LTRIM(RTRIM(ISNULL(ob.officialType, '')))) = 'OFFICIAL TIME' THEN 'OT'
                    ELSE 'OB'
                END
            WHEN d.dtr_daily_id IS NULL AND cto.ctoId IS NOT NULL THEN 'CTO'
            WHEN d.dtr_daily_id IS NULL AND tc.timeCorrectionId IS NOT NULL THEN 'TIME CORRECTED'
            WHEN d.dtr_daily_id IS NULL AND ps.passSlipId IS NOT NULL THEN 'PASS SLIP'
            WHEN d.dtr_daily_id IS NULL THEN 'ABSENT'
            ELSE ISNULL(d.attendance_status, '')
        END AS remarks,
        DATENAME(WEEKDAY, dr.work_date) AS dayDescription,
        CASE WHEN ISNULL(ws.isDayOff, 0) = 1 THEN 'REST DAY' ELSE '' END AS dayOff,
        CAST((ISNULL(d.total_late_minutes, 0) + ISNULL(d.total_undertime_minutes, 0)) / 60 AS int) AS underMinHours,
        ISNULL(la.leaveType, '') AS leaveType,
        CASE
            WHEN ob.officialEngagementApplicationId IS NULL THEN ''
            WHEN UPPER(LTRIM(RTRIM(ISNULL(ob.officialType, '')))) = 'OFFICIAL TIME' THEN 'OT'
            ELSE 'OB'
        END AS ob,
        CASE WHEN otx.overtimeRequestId IS NULL THEN '' ELSE 'OT' END AS ot,
        CASE WHEN cto.ctoId IS NULL THEN '' ELSE 'CTO' END AS cto,
        CASE WHEN ob.officialEngagementApplicationId IS NULL THEN NULL ELSE dr.work_date END AS obDate,
        CASE WHEN otx.overtimeRequestId IS NULL THEN NULL ELSE dr.work_date END AS otDate,
        CAST(NULL AS time) AS nextDayholder,
        CAST(0 AS bit) AS isForNextDay,
        ps.passSlipId,
        CAST(ps.departureTime AS time) AS psDepartureTime,
        CAST(ps.arrivalTime AS time) AS psArrivalTime,
        tc.timeCorrectionId,
        CAST(tc.correctedTimeIn AS time) AS tcTimeIn,
        CAST(tc.correctedBreakOut AS time) AS tcBreakOut,
        CAST(tc.correctedBreakIn AS time) AS tcBreakIn,
        CAST(tc.correctedTimeOut AS time) AS tcTimeOut,
        d.dtr_daily_id,
        ei.employeeId,
        ei.employeeNo
    FROM DateRange dr
    CROSS JOIN EmpInfo ei
    LEFT JOIN dtr_daily d ON d.work_date = dr.work_date
        AND (
            d.employee_id = CAST(ei.employeeId AS varchar(50))
            OR d.employee_id = ei.employeeNo
            OR d.employee_id = $P{EMPLOYEE_ID}
        )
    OUTER APPLY (
        SELECT TOP 1 ws2.isDayOff
        FROM work_schedule ws2
        WHERE (
                CAST(ws2.employeeId AS varchar(50)) = CAST(ei.employeeId AS varchar(50))
                OR CAST(ws2.employeeId AS varchar(50)) = ei.employeeNo
                OR CAST(ws2.employeeId AS varchar(50)) = $P{EMPLOYEE_ID}
              )
          AND CAST(ws2.wsDateTime AS date) = dr.work_date
        ORDER BY ws2.wsId
    ) ws
    LEFT JOIN official_engagement_application ob ON ob.employeeId = ei.employeeId AND ob.status = 'Approved' AND dr.work_date BETWEEN ob.startDate AND ob.endDate
    LEFT JOIN overtime_request otx ON otx.employeeId = ei.employeeId AND otx.status = 'Approved' AND dr.work_date = CAST(otx.dateTimeFrom AS date)
    LEFT JOIN compensatory_time_off cto ON cto.employeeId = ei.employeeId AND cto.status = 'Approved' AND dr.work_date = cto.dateOfOffset
    OUTER APPLY (
        SELECT TOP 1
            ps2.passSlipId,
            ps2.departureTime,
            ps2.arrivalTime
        FROM pass_slip ps2
        WHERE ps2.employeeId = ei.employeeId
          AND ps2.status = 'Approved'
          AND ps2.passSlipDate = dr.work_date
        ORDER BY ps2.passSlipId DESC
    ) ps
    OUTER APPLY (
        SELECT TOP 1
            tc2.timeCorrectionId,
            tc2.correctedTimeIn,
            tc2.correctedBreakOut,
            tc2.correctedBreakIn,
            tc2.correctedTimeOut
        FROM time_correction tc2
        WHERE tc2.employeeId = ei.employeeId
          AND tc2.status = 'Approved'
          AND tc2.workDate = dr.work_date
        ORDER BY tc2.timeCorrectionId DESC
    ) tc
    OUTER APPLY (
        SELECT TOP 1 la2.leaveType
        FROM leave_application la2
        WHERE la2.employeeId = ei.employeeId
          AND la2.approvedStatus = 'Approved'
          AND dr.work_date BETWEEN la2.startDate AND la2.endDate
        ORDER BY la2.leaveApplicationId DESC
    ) la
),
Seg AS (
    -- Normal same-day segment rows.
    SELECT
        ds.dtr_daily_id,
        d.work_date AS reportDate,
        ds.segment_no AS segmentNo,
        0 AS splitOrder,
        CASE
            WHEN ds.break_in IS NOT NULL THEN CAST(ds.time_in AS time)
            WHEN CAST(ds.time_out AS time) < CAST(ds.time_in AS time) THEN NULL
            WHEN CAST(ds.time_in AS time) < CAST('12:00:00' AS time) THEN CAST(ds.time_in AS time)
            ELSE NULL
        END AS in1st,
        CASE
            WHEN ds.break_out IS NOT NULL THEN CAST(ds.break_out AS time)
            WHEN CAST(ds.time_out AS time) < CAST(ds.time_in AS time) THEN NULL
            WHEN CAST(ds.time_out AS time) <= CAST('12:00:00' AS time) THEN CAST(ds.time_out AS time)
            ELSE NULL
        END AS out1st,
        CASE
            WHEN ds.break_in IS NOT NULL THEN CAST(ds.break_in AS time)
            WHEN CAST(ds.time_in AS time) >= CAST('12:00:00' AS time) THEN CAST(ds.time_in AS time)
            ELSE NULL
        END AS in2nd,
        CASE
            WHEN ds.break_in IS NOT NULL THEN CAST(ds.time_out AS time)
            WHEN CAST(ds.time_out AS time) < CAST(ds.time_in AS time) THEN NULL
            WHEN CAST(ds.time_in AS time) >= CAST('12:00:00' AS time) THEN CAST(ds.time_out AS time)
            WHEN CAST(ds.time_in AS time) < CAST('12:00:00' AS time)
                 AND CAST(ds.time_out AS time) > CAST('12:00:00' AS time) THEN CAST(ds.time_out AS time)
            ELSE NULL
        END AS out2nd,
        CAST((ISNULL(ds.late_minutes, 0) + ISNULL(ds.undertime_minutes, 0)) % 60 AS int) AS segmentUnderMin,
        CAST((ISNULL(ds.late_minutes, 0) + ISNULL(ds.undertime_minutes, 0)) / 60 AS int) AS segmentUnderMinHours
    FROM dtr_segment ds
    INNER JOIN dtr_daily d ON d.dtr_daily_id = ds.dtr_daily_id
    INNER JOIN EmpInfo ei ON d.employee_id = CAST(ei.employeeId AS varchar(50)) OR d.employee_id = ei.employeeNo OR d.employee_id = $P{EMPLOYEE_ID}
    WHERE NOT (CAST(ds.time_out AS time) < CAST(ds.time_in AS time))
      AND d.work_date BETWEEN DATEADD(day, -1, CAST($P{fromDate} AS date)) AND CAST($P{toDate} AS date)

    UNION ALL

    -- Overnight start row: display night time-in on the actual work date.
    SELECT
        ds.dtr_daily_id,
        d.work_date AS reportDate,
        ds.segment_no AS segmentNo,
        0 AS splitOrder,
        CAST(NULL AS time) AS in1st,
        CAST(NULL AS time) AS out1st,
        CAST(ds.time_in AS time) AS in2nd,
        CAST(NULL AS time) AS out2nd,
        CAST((ISNULL(ds.late_minutes, 0) + ISNULL(ds.undertime_minutes, 0)) % 60 AS int) AS segmentUnderMin,
        CAST((ISNULL(ds.late_minutes, 0) + ISNULL(ds.undertime_minutes, 0)) / 60 AS int) AS segmentUnderMinHours
    FROM dtr_segment ds
    INNER JOIN dtr_daily d ON d.dtr_daily_id = ds.dtr_daily_id
    INNER JOIN EmpInfo ei ON d.employee_id = CAST(ei.employeeId AS varchar(50)) OR d.employee_id = ei.employeeNo OR d.employee_id = $P{EMPLOYEE_ID}
    WHERE CAST(ds.time_out AS time) < CAST(ds.time_in AS time)
      AND d.work_date BETWEEN DATEADD(day, -1, CAST($P{fromDate} AS date)) AND CAST($P{toDate} AS date)

    UNION ALL

    -- Overnight end row: display next-day morning departure on the following date.
    SELECT
        ds.dtr_daily_id,
        DATEADD(day, 1, d.work_date) AS reportDate,
        ds.segment_no AS segmentNo,
        1 AS splitOrder,
        CAST(NULL AS time) AS in1st,
        CAST(ds.time_out AS time) AS out1st,
        CAST(NULL AS time) AS in2nd,
        CAST(NULL AS time) AS out2nd,
        CAST(0 AS int) AS segmentUnderMin,
        CAST(0 AS int) AS segmentUnderMinHours
    FROM dtr_segment ds
    INNER JOIN dtr_daily d ON d.dtr_daily_id = ds.dtr_daily_id
    INNER JOIN EmpInfo ei ON d.employee_id = CAST(ei.employeeId AS varchar(50)) OR d.employee_id = ei.employeeNo OR d.employee_id = $P{EMPLOYEE_ID}
    WHERE CAST(ds.time_out AS time) < CAST(ds.time_in AS time)
      AND DATEADD(day, 1, d.work_date) BETWEEN CAST($P{fromDate} AS date) AND CAST($P{toDate} AS date)
)
SELECT
    CAST(COALESCE(s.reportDate, b.dtrDate) AS date) AS dtrDate,
    b.fullname,
    s.in1st,
    s.out1st,
    s.in2nd,
    s.out2nd,
    b.regMin,
    b.excessMin,
    b.ndApproved,
    b.otReg,
    b.otExcess,
    b.otRegApproved,
    b.otExcessApproved,
    b.lateMin,
    CASE WHEN s.segmentNo IS NULL THEN b.underMin ELSE s.segmentUnderMin END AS underMin,
    b.absentMin,
    b.ob,
    b.ot,
    b.obDate,
    b.otDate,
    b.dayOff,
    CASE WHEN s.segmentNo IS NULL THEN b.underMinHours ELSE s.segmentUnderMinHours END AS underMinHours,
    b.remarks,
    b.leaveType,
    b.nextDayholder,
    b.isForNextDay,
    b.cto,
    DATENAME(WEEKDAY, COALESCE(s.reportDate, b.dtrDate)) AS dayDescription,
    ISNULL(s.segmentNo, 0) AS sortSegmentNo,
    ISNULL(s.splitOrder, 0) AS sortSplitOrder
FROM DailyBase b
LEFT JOIN Seg s ON s.dtr_daily_id = b.dtr_daily_id AND s.reportDate = b.dtrDate
WHERE NOT (
    b.dtr_daily_id IS NULL
    AND EXISTS (
        SELECT 1
        FROM dtr_segment dsx
        INNER JOIN dtr_daily dx ON dx.dtr_daily_id = dsx.dtr_daily_id
        WHERE CAST(dsx.time_out AS time) < CAST(dsx.time_in AS time)
          AND DATEADD(day, 1, dx.work_date) = b.dtrDate
          AND (dx.employee_id = CAST(b.employeeId AS varchar(50)) OR dx.employee_id = b.employeeNo OR dx.employee_id = $P{EMPLOYEE_ID})
    )
)
AND NOT (b.passSlipId IS NOT NULL AND s.segmentNo IS NULL)
AND b.timeCorrectionId IS NULL

UNION ALL

SELECT
    CAST(s.reportDate AS date) AS dtrDate,
    b.fullname,
    s.in1st,
    s.out1st,
    s.in2nd,
    s.out2nd,
    0 AS regMin,
    b.excessMin,
    b.ndApproved,
    0.0 AS otReg,
    b.otExcess,
    0.0 AS otRegApproved,
    b.otExcessApproved,
    0 AS lateMin,
    s.segmentUnderMin AS underMin,
    0 AS absentMin,
    '' AS ob,
    '' AS ot,
    CAST(NULL AS date) AS obDate,
    CAST(NULL AS date) AS otDate,
    '' AS dayOff,
    s.segmentUnderMinHours AS underMinHours,
    'Present' AS remarks,
    '' AS leaveType,
    b.nextDayholder,
    CAST(1 AS bit) AS isForNextDay,
    '' AS cto,
    DATENAME(WEEKDAY, s.reportDate) AS dayDescription,
    s.segmentNo AS sortSegmentNo,
    s.splitOrder AS sortSplitOrder
FROM DailyBase b
INNER JOIN Seg s ON s.dtr_daily_id = b.dtr_daily_id AND s.reportDate <> b.dtrDate
WHERE s.reportDate BETWEEN $P{fromDate} AND $P{toDate}
  AND NOT EXISTS (
      SELECT 1
      FROM time_correction tcx
      WHERE tcx.employeeId = b.employeeId
        AND tcx.status = 'Approved'
        AND tcx.workDate = s.reportDate
  )

UNION ALL

-- An approved Time Correction is authoritative for the four DTR punches.
-- It replaces biometric/previous segment values for the corrected work date.
SELECT
    CAST(b.dtrDate AS date) AS dtrDate,
    b.fullname,
    b.tcTimeIn AS in1st,
    b.tcBreakOut AS out1st,
    b.tcBreakIn AS in2nd,
    b.tcTimeOut AS out2nd,
    b.regMin,
    b.excessMin,
    b.ndApproved,
    b.otReg,
    b.otExcess,
    b.otRegApproved,
    b.otExcessApproved,
    b.lateMin,
    b.underMin,
    0 AS absentMin,
    '' AS ob,
    '' AS ot,
    CAST(NULL AS date) AS obDate,
    CAST(NULL AS date) AS otDate,
    '' AS dayOff,
    b.underMinHours,
    'TIME CORRECTED' AS remarks,
    '' AS leaveType,
    CAST(NULL AS time) AS nextDayholder,
    CAST(0 AS bit) AS isForNextDay,
    '' AS cto,
    DATENAME(WEEKDAY, b.dtrDate) AS dayDescription,
    0 AS sortSegmentNo,
    0 AS sortSplitOrder
FROM DailyBase b
WHERE b.timeCorrectionId IS NOT NULL

UNION ALL

-- Approved Pass Slip movements are separate report rows so they never
-- overwrite biometric DTR segments recorded on the same date.
SELECT
    CAST(b.dtrDate AS date) AS dtrDate,
    b.fullname,
    CASE
        WHEN b.psArrivalTime < CAST('12:00:00' AS time) THEN b.psArrivalTime
        ELSE CAST(NULL AS time)
    END AS in1st,
    CASE
        WHEN b.psDepartureTime < CAST('12:00:00' AS time) THEN b.psDepartureTime
        ELSE CAST(NULL AS time)
    END AS out1st,
    CASE
        WHEN b.psArrivalTime >= CAST('12:00:00' AS time) THEN b.psArrivalTime
        ELSE CAST(NULL AS time)
    END AS in2nd,
    CASE
        WHEN b.psDepartureTime >= CAST('12:00:00' AS time) THEN b.psDepartureTime
        ELSE CAST(NULL AS time)
    END AS out2nd,
    0 AS regMin,
    0 AS excessMin,
    0.0 AS ndApproved,
    0.0 AS otReg,
    0.0 AS otExcess,
    0.0 AS otRegApproved,
    0.0 AS otExcessApproved,
    0 AS lateMin,
    0 AS underMin,
    0 AS absentMin,
    '' AS ob,
    '' AS ot,
    CAST(NULL AS date) AS obDate,
    CAST(NULL AS date) AS otDate,
    '' AS dayOff,
    0 AS underMinHours,
    'PASS SLIP' AS remarks,
    '' AS leaveType,
    CAST(NULL AS time) AS nextDayholder,
    CAST(0 AS bit) AS isForNextDay,
    '' AS cto,
    DATENAME(WEEKDAY, b.dtrDate) AS dayDescription,
    9999 AS sortSegmentNo,
    0 AS sortSplitOrder
FROM DailyBase b
WHERE b.passSlipId IS NOT NULL
ORDER BY dtrDate, sortSegmentNo, sortSplitOrder
OPTION (MAXRECURSION 366)
]]></query>
	<field name="dtrDate" class="java.sql.Date"/>
	<field name="fullname" class="java.lang.String"/>
	<field name="in1st" class="java.sql.Time"/>
	<field name="out1st" class="java.sql.Time"/>
	<field name="in2nd" class="java.sql.Time"/>
	<field name="out2nd" class="java.sql.Time"/>
	<field name="regMin" class="java.lang.Integer"/>
	<field name="excessMin" class="java.lang.Integer"/>
	<field name="ndApproved" class="java.lang.Double"/>
	<field name="otReg" class="java.lang.Double"/>
	<field name="otExcess" class="java.lang.Double"/>
	<field name="otRegApproved" class="java.lang.Double"/>
	<field name="otExcessApproved" class="java.lang.Double"/>
	<field name="lateMin" class="java.lang.Integer"/>
	<field name="underMin" class="java.lang.Integer"/>
	<field name="absentMin" class="java.lang.Integer"/>
	<field name="ob" class="java.lang.String"/>
	<field name="ot" class="java.lang.String"/>
	<field name="obDate" class="java.sql.Date"/>
	<field name="otDate" class="java.sql.Date"/>
	<field name="dayOff" class="java.lang.String"/>
	<field name="underMinHours" class="java.lang.Integer"/>
	<field name="remarks" class="java.lang.String"/>
	<field name="leaveType" class="java.lang.String"/>
	<field name="nextDayholder" class="java.sql.Time"/>
	<field name="isForNextDay" class="java.lang.Boolean"/>
	<field name="cto" class="java.lang.String"/>
	<field name="dayDescription" class="java.lang.String"/>
	<variable name="hoursWorked" class="java.lang.Double">
		<expression><![CDATA[new Double(Double.valueOf($F{regMin}.intValue() + $F{excessMin}.intValue()).doubleValue()/60)]]></expression>
		<initialValueExpression><![CDATA[new Double(0.0)]]></initialValueExpression>
	</variable>
	<variable name="ot" class="java.lang.Double">
		<expression><![CDATA[new Double($F{otReg}.doubleValue() + $F{otExcess}.doubleValue())]]></expression>
		<initialValueExpression><![CDATA[new Double(0.0)]]></initialValueExpression>
	</variable>
	<variable name="otApproved" class="java.lang.Double">
		<expression><![CDATA[new Double($F{otRegApproved}.doubleValue() + $F{otExcessApproved}.doubleValue())]]></expression>
		<initialValueExpression><![CDATA[new Double(0.0)]]></initialValueExpression>
	</variable>
